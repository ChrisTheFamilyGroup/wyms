{%- liquid
  assign top_icon   = product.metafields.custom.top_left_icon.value
  assign spot_bg    = product.metafields.custom.spot_background.value
  assign model_name = product.metafields.custom.model_name.value
  assign price      = product.price | money
  assign compare    = product.compare_at_price

  assign card_variant = product.selected_or_first_available_variant

  assign card_color = ''
  assign card_color_mf = card_variant.metafields.shopify['color-pattern']
  if card_color_mf == blank
    assign card_color_mf = product.metafields.shopify['color-pattern']
  endif
  if card_color_mf != blank
    assign card_color = card_color_mf | metafield_text: field: 'label' | strip
    if card_color == blank
      assign card_color = card_color_mf | metafield_text: field: 'name' | strip
    endif
  endif
  if card_color == blank and card_color_mf != blank
    assign card_color_val = card_color_mf.value
    if card_color_mf.list?
      assign card_color_val = card_color_val.first
    endif
    if card_color_val.label != blank
      assign card_color = card_color_val.label | strip
    elsif card_color_val.name != blank
      assign card_color = card_color_val.name | strip
    elsif card_color_val != blank
      assign card_color = card_color_val | strip
    endif
  endif
  if card_color == blank
    for product_option in product.options_with_values
      assign card_opt_str = ''
      assign card_swatch_opts = product_option.values | map: 'swatch' | compact | size
      if card_swatch_opts == 0
        continue
      endif
      case product_option.position
        when 1
          assign card_opt_str = card_variant.option1 | strip
        when 2
          assign card_opt_str = card_variant.option2 | strip
        when 3
          assign card_opt_str = card_variant.option3 | strip
      endcase
      if card_opt_str == blank
        continue
      endif
      for product_option_value in product_option.values
        if product_option_value.name == card_opt_str
          assign card_color = product_option_value.name | strip
          break
        endif
      endfor
      if card_color != blank
        break
      endif
    endfor
  endif
  if card_color == blank
    for product_option in product.options_with_values
      assign opt_name_l = product_option.name | downcase | strip
      if opt_name_l == 'color' or opt_name_l == 'colour' or opt_name_l == 'farbe'
        case product_option.position
          when 1
            assign card_color = card_variant.option1 | default: '' | strip
          when 2
            assign card_color = card_variant.option2 | default: '' | strip
          when 3
            assign card_color = card_variant.option3 | default: '' | strip
        endcase
        break
      endif
    endfor
  endif

  assign card_color_line = card_color | default: product.title
-%}

<article class="wyms-product-card" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="wyms-product-card__link" aria-label="{{ product.title | escape }}">

    <div class="wyms-product-card__image-wrap">

      {%- if top_icon -%}
        <div class="wyms-product-card__top-left-icon">
          <img
            src="{{ top_icon | image_url: width: 76 }}"
            alt=""
            width="76"
            height="40"
            loading="lazy">
        </div>
      {%- endif -%}

      <button
        class="wyms-product-card__wishlist"
        aria-label="Add to wishlist"
        type="button"
        data-product-id="{{ product.id }}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 21C12 21 3 15.5 3 9C3 6.23858 5.23858 4 8 4C9.5 4 10.8 4.7 12 6C13.2 4.7 14.5 4 16 4C18.7614 4 21 6.23858 21 9C21 15.5 12 21 12 21Z"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="wyms-product-card__spot-wrap">
        {%- if spot_bg -%}
          <img
            class="wyms-product-card__spot"
            src="{{ spot_bg | image_url: width: 424 }}"
            width=""
            height=""
            alt=""
            aria-hidden="true"
            loading="lazy">
        {%- endif -%}

        {%- if product.featured_image -%}
          <img
            class="wyms-product-card__img"
            src="{{ product.featured_image | image_url: width: 424 }}"
            srcset="
              {{ product.featured_image | image_url: width: 320 }} 320w,
              {{ product.featured_image | image_url: width: 424 }} 424w,
              {{ product.featured_image | image_url: width: 600 }} 600w"
            sizes="(max-width: 767px) 100vw, (max-width: 1199px) 50vw, 33vw"
            alt="{{ product.featured_image.alt | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="lazy">
        {%- endif -%}
      </div>

    </div>

    <div class="wyms-product-card__info">
      <div class="wyms-product-card__info-inner">
        <div class="wyms-product-card__text-price">

          <div class="wyms-product-card__text">
            <span class="wyms-product-card__title">{{ card_color_line }}</span>
            {%- if model_name -%}
              <span class="wyms-product-card__model">{{ model_name }}</span>
            {%- endif -%}
          </div>

          <div class="wyms-product-card__price-wrap">
            {%- if compare and compare > product.price -%}
              <s class="wyms-product-card__price wyms-product-card__price--compare">
                {{ compare | money }}
              </s>
            {%- endif -%}
            <span class="wyms-product-card__price">{{ price }}</span>
          </div>

        </div>
      </div>
    </div>

  </a>
</article>