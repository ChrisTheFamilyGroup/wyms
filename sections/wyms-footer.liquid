{{ 'wyms-footer.css' | asset_url | stylesheet_tag }}

<wyms-footer class="footer-section">

  <div class="footer-newsletter-wrapper">
    <div class="footer-newsletter">

      {%- if section.settings.blob_left != blank -%}
        <div class="footer-newsletter__blob footer-newsletter__blob--left hide-mobile">
          {{
            section.settings.blob_left
            | image_url: width: 600
            | image_tag: loading: 'lazy'
          }}
        </div>
      {%- endif -%}

      {%- if section.settings.blob_right != blank -%}
        <div class="footer-newsletter__blob footer-newsletter__blob--right hide-mobile">
          {{
            section.settings.blob_right
            | image_url: width: 600
            | image_tag: loading: 'lazy'
          }}
        </div>
      {%- endif -%}

      {%- if section.settings.blob_mobile != blank -%}
        <div class="footer-newsletter__blob footer-newsletter__blob--center hide-desktop">
          {{
            section.settings.blob_mobile
            | image_url: width: 600
            | image_tag: loading: 'lazy'
          }}
        </div>
      {%- endif -%}

      <div class="footer-newsletter__content">
        {%- if section.settings.nl_title != blank -%}
          <h2 class="footer-newsletter__title">
            {{ section.settings.nl_title }}
          </h2>
        {%- endif -%}

        <div class="footer-newsletter__form-container">
          {% form 'customer', class: 'footer-newsletter__form' %}
            <input
              type="hidden"
              name="contact[tags]"
              value="newsletter"
            >
            <div class="footer-newsletter__input-wrapper">
              <input
                type="email"
                name="contact[email]"
                class="footer-newsletter__input"
                placeholder="{{ section.settings.nl_placeholder }}"
                required
              >
              <button
                type="submit"
                class="footer-newsletter__submit"
                aria-label="Subscribe"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M5 12H19M19 12L12 5M19 12L12 19"
                    stroke="#242352"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
            </div>
          {% endform %}

          {%- if section.settings.nl_subtext != blank -%}
            <p class="footer-newsletter__subtext">
              {{ section.settings.nl_subtext }}
            </p>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>

  <div class="footer-main-bg">
    <div class="footer-main-inner">

      <div class="footer-grid">

        <div class="footer-col footer-col--logo">
          <a href="{{ routes.root_url }}">
            {%- if section.settings.logo != blank -%}
              {{
                section.settings.logo
                | image_url: width: 254
                | image_tag: class: 'footer-logo-img', loading: 'lazy'
              }}
            {%- else -%}
              <span style="color: #FFF; font-size: 24px; font-weight: bold;">
                {{ shop.name }}
              </span>
            {%- endif -%}
          </a>
        </div>

        <div class="footer-col footer-col--links">
          {%- for i in (1..3) -%}
            {%- assign menu_key = "menu_" | append: i -%}
            {%- assign menu = linklists[section.settings[menu_key]] -%}
            {%- if menu != blank and menu.links.size > 0 -%}
              <div class="footer-nav-block">
                <h4 class="footer-nav-title">
                  {{ menu.title }}
                </h4>
                <div class="footer-nav-list">
                  {%- for link in menu.links -%}
                    <a
                      href="{{ link.url }}"
                      class="footer-nav-link"
                    >
                      {{ link.title }}
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="footer-col footer-col--info">

          <div class="footer-info-block">
            <h4 class="footer-nav-title">
              {{ section.settings.payment_title }}
            </h4>
            <div class="footer-payment-icons">
              {%- for block in section.blocks -%}
                {%- if block.type == 'payment_icon' and block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 68
                    | image_tag: class: 'payment-icon-img', loading: 'lazy'
                  }}
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

          <div class="footer-info-block">
            <h4 class="footer-nav-title">
              {{ section.settings.brands_title }}
            </h4>
            {%- if section.settings.brands_logo != blank -%}
              <a
                href="{{ section.settings.brands_url | default: '#' }}"
                target="_blank"
                rel="noopener noreferrer"
              >
                {{
                  section.settings.brands_logo
                  | image_url: width: 186
                  | image_tag: class: 'brands-logo-img', loading: 'lazy'
                }}
              </a>
            {%- endif -%}
          </div>

        </div>

      </div>

      <div class="footer-bottom-bar">

        <div class="footer-bottom-left">
          <span class="footer-copyright">
            &copy; {{ 'now' | date: "%Y" }} {{ section.settings.copyright_text }}
          </span>
          {%- assign bottom_menu = linklists[section.settings.bottom_menu] -%}
          {%- if bottom_menu != blank -%}
            <div class="footer-bottom-links">
              {%- for link in bottom_menu.links -%}
                <a
                  href="{{ link.url }}"
                  class="footer-bottom-link"
                >
                  {{ link.title }}
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="footer-bottom-right">
          <div class="footer-socials">
            {%- for block in section.blocks -%}
              {%- if block.type == 'social_icon' and block.settings.icon != blank -%}
                <a
                  href="{{ block.settings.link | default: '#' }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-link"
                  {{ block.shopify_attributes }}
                >
                  {{
                    block.settings.icon
                    | image_url: width: 40
                    | image_tag: class: 'social-icon-img', loading: 'lazy'
                  }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      </div>

    </div>
  </div>

</wyms-footer>

{% schema %}
{
  "name": "WYMS Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter Section"
    },
    {
      "type": "text",
      "id": "nl_title",
      "label": "Title",
      "default": "Join our newsletter to stay up to date"
    },
    {
      "type": "text",
      "id": "nl_placeholder",
      "label": "Input Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "textarea",
      "id": "nl_subtext",
      "label": "Consent Text",
      "default": "By subscribing you agree to with our Privacy Policy..."
    },
    {
      "type": "header",
      "content": "Newsletter Blobs (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "blob_left",
      "label": "Left Blob"
    },
    {
      "type": "image_picker",
      "id": "blob_right",
      "label": "Right Blob"
    },
    {
      "type": "header",
      "content": "Newsletter Blob (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "blob_mobile",
      "label": "Mobile Blob (Centered)"
    },
    {
      "type": "header",
      "content": "Footer Main Grid"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu Column 1"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu Column 2"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu Column 3"
    },
    {
      "type": "header",
      "content": "Payment & Brands"
    },
    {
      "type": "text",
      "id": "payment_title",
      "label": "Payment Title",
      "default": "Payment methods"
    },
    {
      "type": "text",
      "id": "brands_title",
      "label": "Brands Title",
      "default": "Unsere Marken"
    },
    {
      "type": "image_picker",
      "id": "brands_logo",
      "label": "Brands Logo"
    },
    {
      "type": "url",
      "id": "brands_url",
      "label": "Brands Link"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Wyms. Alle Rechte vorbehalten."
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom Links Menu"
    }
  ],
  "blocks": [
    {
      "type": "payment_icon",
      "name": "Payment Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Payment Image"
        }
      ]
    },
    {
      "type": "social_icon",
      "name": "Social Media Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Social Icon"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Profile Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WYMS Footer",
      "blocks": [
        { "type": "payment_icon" },
        { "type": "payment_icon" },
        { "type": "social_icon" },
        { "type": "social_icon" }
      ]
    }
  ]
}
{% endschema %}
