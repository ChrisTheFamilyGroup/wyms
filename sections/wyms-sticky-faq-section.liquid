<div class="wyms-sticky-faq-section">
    <div class="page-width">
        <div class="sticky-faq-container">

            <!-- Sidebar -->
            <div class="sticky-faq-sidebar">
                <ul class="items faq-sidebar-list">
                    {% for block in section.blocks %}
                        {% if block.type == 'category' %}
                            <li class="faq-sidebar-item stack-spacious-group-gap">
                                <div class="faq-sidebar-info small-heading">
                                    <a href="#cat-{{ block.id }}" class="h5-heading">{{ block.settings.title }}</a>
                                </div>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>

            <!-- Content -->
            <div class="sticky-faq-inner-content">
                <div class="sticky-faq-content">

                    {% for block in section.blocks %}

                        {% case block.type %}

                        {% when 'category' %}

                        <div class="sticky-faq-details" id="cat-{{ block.id }}">
                            <div class="sticky-faq-info">
                                <div class="sub-text text-spacious-heading-gap">
                                    <h2 class="h4-heading">{{ block.settings.title }}</h2>
                                    <div class="heading-icon">
                                        {% if block.settings.heading_icon != blank %}
                                            <img
                                                srcset="
                                                {%- if block.settings.heading_icon.width >= 165 -%}{{ block.settings.heading_icon | image_url: width: 165 }} 165w,{%- endif -%}
                                                {%- if block.settings.heading_icon.width >= 360 -%}{{ block.settings.heading_icon | image_url: width: 360 }} 360w,{%- endif -%}
                                                {%- if block.settings.heading_icon.width >= 533 -%}{{ block.settings.heading_icon | image_url: width: 533 }} 533w,{%- endif -%}
                                                {%- if block.settings.heading_icon.width >= 720 -%}{{ block.settings.heading_icon | image_url: width: 720 }} 720w,{%- endif -%}
                                                {%- if block.settings.heading_icon.width >= 940 -%}{{ block.settings.heading_icon | image_url: width: 940 }} 940w,{%- endif -%}
                                                {%- if block.settings.heading_icon.width >= 1066 -%}{{ block.settings.heading_icon | image_url: width: 1066 }} 1066w,{%- endif -%}
                                                {{ block.settings.heading_icon | image_url }} {{ block.settings.heading_icon.width }}w
                                                "
                                                src="{{ block.settings.heading_icon | image_url: width: 533 }}"
                                                alt="{{ block.settings.heading_icon.alt | escape }}"
                                                class="img-fluid main-heading-icon"
                                                loading="lazy"
                                                width="{{ block.settings.heading_icon.width }}"
                                                height="{{ block.settings.heading_icon.height }}"
                                            >
                                        {% endif %}
                                </div>
                                </div>

                                <div class="sticky-faq-accordion">

                        {% when 'faq' %}

                                    <div class="sticky-faq-item">

                                        <button
                                            type="button"
                                            class="faq-question Bt1-18_medium"
                                            aria-expanded="false"
                                            aria-controls="faq-answer-{{ block.id }}"
                                        >
                                            {{ block.settings.question }}

                                            <span class="sticky-faq-arrow close" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                                <path d="M8 1V15M1 8H15" stroke="#00103F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </span>

                                            <span class="sticky-faq-arrow open" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                                <path d="M5 12H19" stroke="#00103F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>                                            
                                            </span>

                                        </button>

                                        <div
                                            id="faq-answer-{{ block.id }}"
                                            class="sticky-faq-answer text-regular-list-item-gap"
                                            role="region"
                                        >
                                            {{ block.settings.answer }}
                                        </div>

                                    </div>

                        {% endcase %}

                        {% assign nextBlock = section.blocks[forloop.index] %}

                        {% if nextBlock.type == 'category' or forloop.last %}
                                </div>
                            </div>
                        </div>
                        {% endif %}

                    {% endfor %}

                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .wyms-sticky-faq-section {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }

    html.js.page-faq { scroll-behavior: smooth; }

    @media (prefers-reduced-motion: reduce) {
      html.js.page-faq { scroll-behavior: auto; }
    }
    .wyms-sticky-faq-section .sticky-faq-container {display: flex; gap: 32px;}
    .sticky-faq-container .sticky-faq-sidebar {width: 100%; max-width: 320px; position: sticky; top: 14%; height: 100%; }
    .sticky-faq-container .sticky-faq-inner-content {width: 720px; }
    .sticky-faq-item .sticky-faq-answer { height: 0; overflow: hidden; transition: height 0.35s ease; padding-right: 20px; }
    .sticky-faq-accordion .sticky-faq-item .faq-question { font-family: var(--font-family-body); color: #00103F; font-size: 20px; font-style: normal; font-weight: 500; line-height: 30px; width: 100%; background: none; border: none; align-items: center;  text-align: left; display: flex; justify-content: space-between; cursor: pointer; padding: 0; outline: none; box-shadow: none;}
    .faq-sidebar-item .faq-sidebar-info a {text-decoration: none; width: 100%; display: flex; font-family: var(--font-family-body); color: #00103F; font-size: 16px; font-style: normal; font-weight: 500; line-height: 24px; }
    {% comment %} .faq-sidebar-item .faq-sidebar-info.active a {color: #1E1E1E;} {% endcomment %}
    .sticky-faq-container .sticky-faq-sidebar .faq-sidebar-list { background-color: transparent; padding: 0; margin: 0; list-style: none; }
    .sticky-faq-item .faq-question .sticky-faq-arrow { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; }
    .sticky-faq-item .sticky-faq-answer p { font-family: var(--Font-family-font-family-body, Inter); font-size: 16px; line-height: 24px; font-weight: 400; color: #00103F; margin: 0; padding-top: 8px; }
    .sticky-faq-accordion .sticky-faq-item { margin-bottom: 32px; display: flex; min-width: var(--width-xxs, 320px); max-width: var(--width-xl, 768px); padding: var(--spacing-2xl, 20px) var(--spacing-3xl, 24px); flex-direction: column; align-items: center; align-self: stretch; border-radius: 12px; background: var(--Colors-Base-gray-light, #F7F7F7); }
    .sticky-faq-accordion .sticky-faq-item:last-child {margin-bottom: 0;}
    .sticky-faq-content .sticky-faq-details { padding-bottom: 64px; }
    .sticky-faq-content .sticky-faq-details:last-child {border: 0; padding: 0; margin: 0;}
    .faq-sidebar-list .faq-sidebar-item:last-child {margin-bottom: 0;}
    li.faq-sidebar-item.stack-spacious-group-gap { min-width: 180px; padding: 12px 24px; align-items: center; }
    .sub-text.text-spacious-heading-gap .h4-heading { font-family: var(--font-family-display); color: #00103F; font-size: 30px; font-style: normal; font-weight: 600; line-height: 38px; margin: 0; }
    .sticky-faq-item span.sticky-faq-arrow.open, .sticky-faq-item.open span.sticky-faq-arrow.close { display: none; }
    .sticky-faq-item.open span.sticky-faq-arrow.open { display: block; }
    .sub-text.text-spacious-heading-gap { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
    img.img-fluid.main-heading-icon { height: 28px; width: 28px; object-fit: contain; }
    .heading-icon { display: flex; align-items: center; justify-content: flex-start; }
    li.faq-sidebar-item.stack-spacious-group-gap:hover { background: var(--Colors-Base-gray-light, #F7F7F7); border-radius: 15px; transform: scale(1.02); }
    li.faq-sidebar-item.stack-spacious-group-gap { border-radius: 15px; transition: transform 0.3s ease, background 0.3s ease; }


    @media (max-width:1599px){
        .wyms-sticky-faq-section { padding-top: {{ section.settings.padding_top_laptop }}px; padding-bottom: {{ section.settings.padding_bottom_laptop }}px; }
    }
    @media (max-width: 1399.98px) {
        .sticky-faq-accordion .sticky-faq-item {margin-bottom: 26px;}
    }
    @media (max-width: 1199.98px) {
        .sticky-faq-accordion .sticky-faq-item {margin-bottom: 20px;}
        .sticky-faq-container .sticky-faq-sidebar .faq-sidebar-list {padding: 20px;}
    }
    @media (max-width: 991.98px) {
        .wyms-sticky-faq-section { padding-top: {{ section.settings.padding_top_tablet }}px; padding-bottom: {{ section.settings.padding_bottom_tablet }}px; }
        .sticky-faq-accordion .sticky-faq-item {margin-bottom: 16px;}
        .sticky-faq-container .sticky-faq-sidebar {max-width: 250px;}
    }
    @media (max-width: 767.98px) {
        .wyms-sticky-faq-section  { padding-top: {{ section.settings.padding_top_mobile }}px; padding-bottom: {{ section.settings.padding_bottom_mobile }}px; }

        .sticky-faq-container .sticky-faq-sidebar {max-width: 200px;}
        .sticky-faq-container .sticky-faq-sidebar .faq-sidebar-list {padding: 12px;}
    }
    @media (max-width: 575.98px) {
        .wyms-sticky-faq-section .sticky-faq-container {flex-wrap: wrap;}
        .sticky-faq-container .sticky-faq-sidebar {max-width: 100%; margin-bottom: 24px; position: unset; display: none; }
        .sticky-faq-container .sticky-faq-inner-content {width: 100%; }
        .sticky-faq-accordion .sticky-faq-item { padding: 16px 20px; border-radius: 24px; }
        .sticky-faq-accordion .sticky-faq-item .faq-question { font-size: 18px; }
    }
</style>

<script>
(function () {
  var root = document.getElementById('shopify-section-{{ section.id }}');
  if (!root) return;

  var questions = root.querySelectorAll('.faq-question');
  var items = root.querySelectorAll('.sticky-faq-item');
  var detailsSections = root.querySelectorAll('.sticky-faq-details');
  var navItems = root.querySelectorAll('.faq-sidebar-item a');
  var scrollOffset = 200;

  questions.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var answer = this.parentElement.querySelector('.sticky-faq-answer');
      var item = this.parentElement;
      if (!answer || !item) return;

      items.forEach(function (i) {
        if (i !== item) {
          var a = i.querySelector('.sticky-faq-answer');
          var q = i.querySelector('.faq-question');
          if (a) a.style.height = '0px';
          if (q) q.setAttribute('aria-expanded', 'false');
          i.classList.remove('open');
        }
      });

      if (item.classList.contains('open')) {
        answer.style.height = '0px';
        item.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        answer.style.height = answer.scrollHeight + 'px';
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  function onScrollSpy() {
    var current = '';
    var y = window.scrollY;

    detailsSections.forEach(function (sectionEl) {
      var top = sectionEl.getBoundingClientRect().top + window.scrollY - scrollOffset;
      if (y >= top) {
        current = sectionEl.getAttribute('id') || '';
      }
    });

    navItems.forEach(function (link) {
      var parent = link.parentElement;
      if (!parent) return;
      parent.classList.remove('active');
      if (link.getAttribute('href') === '#' + current) {
        parent.classList.add('active');
      }
    });
  }

  window.addEventListener('scroll', onScrollSpy, { passive: true });
  onScrollSpy();

  navItems.forEach(function (link) {
    link.addEventListener('click', function () {
      navItems.forEach(function (other) {
        if (other.parentElement) other.parentElement.classList.remove('active');
      });
      if (link.parentElement) link.parentElement.classList.add('active');
    });
  });
})();
</script>

{% schema %}
{
    "name": "Main Sticky FAQ",
    "settings": [
        {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Laptop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_laptop",
      "label": "Padding Top (Laptop)",
      "default": 80,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_laptop",
      "label": "Padding Bottom (Laptop)",
      "default": 80,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Tablet Padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    }
    ],
    "blocks": [
        {
            "type": "category",
            "name": "FAQ Category",
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Category Title"
                },
                {
                    "type": "image_picker",
                    "id": "heading_icon",
                    "label": "Heading Icon"
                }
            ]
        },
        {
            "type": "faq",
            "name": "FAQ Item",
            "settings": [
                {
                    "type": "text",
                    "id": "question",
                    "label": "Question"
                },
                {
                    "type": "richtext",
                    "id": "answer",
                    "label": "Answer"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Main Sticky FAQ"
        }
    ]
}
{% endschema %}