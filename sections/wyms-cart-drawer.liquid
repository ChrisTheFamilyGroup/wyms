{{ 'wyms-cart-drawer.css' | asset_url | stylesheet_tag }}

<div
  class="wyms-cart-drawer"
  id="CartDrawer"
  role="dialog"
  aria-modal="true"
  aria-label="{{ section.settings.cart_title }}"
  aria-hidden="true"
>
  <div class="cart-drawer-container">

    <div class="cart-drawer-header">
      <div class="cart-header-inner">
        <h2 class="cart-title">{{ section.settings.cart_title }}</h2>
        <button type="button" class="cart-close-btn js-cart-close" aria-label="{{ 'accessibility.close' | t }}">
          {% render 'icon-close' %}
        </button>
      </div>
    </div>

    <cart-drawer-items id="CartDrawer-CartItems">
      <div class="cart-drawer-main-and-footer">
        <div class="cart-drawer-items-container js-cart-items">
          {% if cart.item_count > 0 %}
            {% for item in cart.items %}
              <div
                class="cart-item"
                id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                data-key="{{ item.key }}"
              >
                <div class="cart-item-image-wrapper" style="background-color: {{ item.product.metafields.custom.cart_background | default: '#F7F7F7' }};">
                  {%- if item.image != blank -%}
                    {{ item.image | image_url: width: 228 | image_tag: alt: item.product.title, loading: 'lazy', width: item.image.width, height: item.image.height }}
                  {%- endif -%}
                </div>

                <div class="cart-item-info">
                  <div class="cart-item-details">
                    <h3 class="item-name">{{ item.product.title }}</h3>
                    <p class="item-price">{{ item.final_line_price | money }}</p>
                    {%- unless item.product.has_only_default_variant -%}
                      <p class="item-variant">{{ item.variant.title }}</p>
                    {%- endunless -%}
                  </div>

                  <div class="cart-item-controls">
                    {% render 'loading-spinner' %}
                    <quantity-input class="quantity-selector">
                      <button type="button" class="qty-btn quantity__button" name="minus" aria-label="Decrease">
                        {% render 'icon-minus' %}
                      </button>
                      
                      <input
                        class="qty-display quantity__input"
                        type="number"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="0"
                        step="1"
                        data-index="{{ item.index | plus: 1 }}"
                        data-quantity-variant-id="{{ item.variant.id }}"
                        data-inventory-qty="{{ item.variant.inventory_quantity }}"
                        data-inventory-management="{{ item.variant.inventory_management }}"
                        data-inventory-policy="{{ item.variant.inventory_policy }}"
                        id="Drawer-quantity-{{ item.index | plus: 1 }}"
                        aria-label="Quantity for {{ item.product.title | escape }}"
                      >
                      
                      {%- liquid
                        assign disable_plus = false
                        if item.variant.inventory_management == 'shopify' and item.variant.inventory_policy == 'deny'
                          if item.quantity >= item.variant.inventory_quantity
                            assign disable_plus = true
                          endif
                        endif
                      -%}
                      
                      <button type="button" class="qty-btn quantity__button" name="plus" aria-label="Increase" {% if disable_plus %}disabled{% endif %}>
                        {% render 'icon-plus' %}
                      </button>
                    </quantity-input>

                    <cart-remove-button data-index="{{ item.index | plus: 1 }}">
                      <button type="button" class="item-remove-btn" aria-label="Remove {{ item.product.title | escape }}">
                        {% render 'icon-trash' %}
                      </button>
                    </cart-remove-button>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="cart-empty-state">
              <div class="cart-empty-icon">
                {% if section.settings.empty_cart_icon != blank %}
                  {{ section.settings.empty_cart_icon | image_url: width: 144 | image_tag }}
                {% else %}
                  {% render 'icon-cart-empty' %}
                {% endif %}
              </div>
              <p class="cart-empty-text">{{ section.settings.empty_cart_text }}</p>
            </div>
          {% endif %}
        </div>

        {% if cart.item_count > 0 %}
          <div class="cart-drawer-footer">
              <!-- RECOMMENDED PRODUCTS BLOCK -->
      <!-- RECOMMENDED PRODUCTS BLOCK -->
<div class="cart-upsell js-cart-upsell"
  data-see-all-label="{{ section.settings.upsell_see_all_label | default: 'See all →' }}"
  data-show-more-label="{{ section.settings.upsell_show_more_label | default: 'See more' }}"
>
  <h3 class="cart-upsell__title">{{ section.settings.upsell_title | default: 'Passend dazu' }}</h3>

  <div class="cart-upsell__slider js-upsell-slider">
    <div class="cart-upsell__track js-upsell-track">
      {%- liquid
        assign cart_handles = ","
        for item in cart.items
          assign cart_handles = cart_handles | append: item.product.handle | append: ","
        endfor

        assign shown_handles = ","

        for item in cart.items
          assign item_color = ""
          assign item_group = ""
          assign item_priority = ""

          for tag in item.product.tags
            if tag contains 'upsell-color:'
              assign item_color = tag
            endif
            if tag contains 'upsell-group:'
              assign item_group = tag
            endif
            if tag contains 'upsell-priority:'
              assign item_priority = tag | remove: 'upsell-priority:'
              assign item_priority = "upsell-group:" | append: item_priority
            endif
          endfor

          if item_color == blank or item_group == blank
            continue
          endif

          assign target_group = item_group
          if item_priority != blank
            assign target_group = item_priority
          endif

          for upsell_prod in collections['all'].products
            assign handle_check = "," | append: upsell_prod.handle | append: ","
            if cart_handles contains handle_check
              continue
            endif
            if shown_handles contains handle_check
              continue
            endif

            unless upsell_prod.tags contains item_color
              continue
            endunless
            unless upsell_prod.tags contains target_group
              continue
            endunless

            render 'wyms-cart-upsell-item', product: upsell_prod
            assign shown_handles = shown_handles | append: upsell_prod.handle | append: ","
          endfor
        endfor
      -%}
    </div>
  </div>

  <div class="cart-upsell__pagination js-upsell-pagination"></div>
</div>

            <div class="footer-divider"></div>

            <div class="cart-total-row">
              <span class="total-label">{{ section.settings.total_label | default: 'Total' }}</span>
              <span class="total-amount">{{ cart.total_price | money }}</span>
            </div>

            <p class="cart-tax-note">{{ section.settings.tax_note | default: 'Taxes and shipping calculated at checkout' }}</p>

            <form action="{{ routes.cart_url }}" method="post" id="cart-drawer-form">
              <button type="submit" name="checkout" class="btn-checkout">
                {{ section.settings.checkout_label | default: 'Checkout' }}
              </button>
            </form>
          </div>
        {% endif %}
      </div>

      {% comment %} <div id="CartDrawer-CartErrors" role="alert" style="color: red; text-align: center; margin-top: 10px;"></div> {% endcomment %}
    </cart-drawer-items>

  </div>
</div>

<script src="{{ 'wyms-cart-drawer.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "WYMS Cart Drawer",
  "settings": [
    { "type": "text", 
      "id": "cart_title", 
      "label": "Cart Title", 
      "default": "Cart" },
    { "type": "image_picker", 
      "id": "empty_cart_icon", 
      "label": "Empty Cart Icon" 
    },
    { "type": "textarea",
      "id": "empty_cart_text", 
      "label": "Empty Cart Text", 
      "default": "Your cart is currently empty." 
    },
    { "type": "text",
      "id": "total_label", 
      "label": "Total Label", 
      "default": "Total" 
    },
    { "type": "text", 
      "id": "checkout_label", 
      "label": "Checkout Label", 
      "default": "Checkout" },
    { "type": "textarea", 
      "id": "tax_note", 
      "label": "Tax Note", 
      "default": "Taxes and shipping calculated at checkout" 
    },
    {
      "type": "text",
      "id": "upsell_title",
      "label": "Upsell Title",
      "default": "Passend dazu"
    },
    {
      "type": "text",
      "id": "upsell_see_all_label",
      "label": "Upsell — See all label",
      "default": "See all →"
    },
    {
      "type": "text",
      "id": "upsell_show_more_label",
      "label": "Upsell — Show more label",
      "default": "See more"
    }
  ],
  "presets": [{ "name": "WYMS Cart Drawer" }]
}
{% endschema %}