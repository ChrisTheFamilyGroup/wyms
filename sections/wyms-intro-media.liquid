{{ 'wyms-intro-media.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_content = false
  if section.settings.heading != blank or section.settings.image != blank
    assign has_content = true
  endif
-%}

{%- if has_content or request.design_mode -%}
  <section class="wyms-intro">
    
    {%- if has_content == false and request.design_mode -%}
      <div class="wyms-intro__empty-state">
        <h3>Intro Media section is empty</h3>
        <p>Please add a heading or an image in the section settings to display it on the storefront.</p>
      </div>
    {%- else -%}

      <div class="wyms-intro__inner page-width">
        
        <div class="wyms-intro__media">
          {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | image_url: width: 1200 }}" 
                 alt="{{ section.settings.heading | escape }}" 
                 class="wyms-intro__main-img" 
                 loading="lazy"
                 width="{{ section.settings.image.width }}"
                 height="{{ section.settings.image.height }}">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg wyms-intro__main-img' }}
          {%- endif -%}
        </div>

        <div class="wyms-intro__content">
          
          {%- if section.settings.gif_image != blank -%}
            <div class="wyms-intro__gif-wrapper">
              <img src="{{ section.settings.gif_image | image_url: width: 360 }}" 
                   alt="Animated detail" 
                   class="wyms-intro__gif" 
                   loading="lazy"
                   width="180"
                   height="180">
            </div>
          {%- endif -%}

          <div class="wyms-intro__text-group">
            <div class="wyms-intro__text-inner">
              {%- if section.settings.heading != blank -%}
                <h2 class="wyms-intro__heading">{{ section.settings.heading }}</h2>
              {%- endif -%}

              {%- if section.settings.middle_text != blank -%}
                <div class="wyms-intro__text-mid">{{ section.settings.middle_text }}</div>
              {%- endif -%}

              {%- if section.settings.bottom_text != blank -%}
                <div class="wyms-intro__text-bottom">{{ section.settings.bottom_text }}</div>
              {%- endif -%}
            </div>
          </div>

        </div>

      </div>

    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "WYMS Intro Media",
  "settings": [
    {
      "type": "header",
      "content": "Image (Left)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Irregular Image"
    },
    {
      "type": "header",
      "content": "Content (Right)"
    },
    {
      "type": "image_picker",
      "id": "gif_image",
      "label": "GIF or Icon"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Heading Text"
    },
    {
      "type": "textarea",
      "id": "middle_text",
      "label": "Middle Text",
      "default": "Middle body text goes here."
    },
    {
      "type": "textarea",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "Bottom highlight text goes here."
    }
  ],
  "presets": [
    {
      "name": "WYMS Intro Media"
    }
  ]
}
{% endschema %}