      var stickyHeight = stickyBar ? stickyBar.offsetHeight : 0;
      var targetTop = target.getBoundingClientRect().top + window.pageYOffset - stickyHeight;

      window.scrollTo({ top: targetTop, behavior: 'smooth' });
    });
  });

});
</script> {% endcomment %}


{% comment %} <script>
  const section = document.querySelector('.sticky-btns-wrap');
const target = document.querySelector('.wyms-ergonomic-content-with-bg');

const placeholder = document.createElement('div');
let offsetTop = section.offsetTop;

window.addEventListener('scroll', () => {
  if (window.scrollY >= offsetTop) {

    if (!section.classList.contains('fix-div')) {
      // add placeholder to prevent jump
      placeholder.style.height = section.offsetHeight + 'px';
      section.parentNode.insertBefore(placeholder, section);

      section.classList.add('fix-div');
      target.classList.add('extra-margin'); // 👈 add class
    }

  } else {

    if (section.classList.contains('fix-div')) {
      section.classList.remove('fix-div');
      target.classList.remove('extra-margin'); // 👈 remove class

      if (placeholder.parentNode) {
        placeholder.parentNode.removeChild(placeholder);
      }
    }

  }
});

// update on resize
window.addEventListener('resize', () => {
  offsetTop = section.offsetTop;
});
</script> {% endcomment %}


{% schema %}
