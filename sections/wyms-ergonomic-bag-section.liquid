<div class="wyms-ergonomic-bag-section">
  <div class="first-section" style="background-image: url('{{ section.settings.first_bg_image | image_url }}');">
    <div class="page-width">
      <div class="first-left-right-parts">
        <div class="first-left-part">
            <div class="main-image">
            {% if section.settings.main_left_image != blank %}
                    <img
                          srcset="
                          {%- if section.settings.main_left_image.width >= 165 -%}{{ section.settings.main_left_image | image_url: width: 165 }} 165w,{%- endif -%}
                          {%- if section.settings.main_left_image.width >= 360 -%}{{ section.settings.main_left_image | image_url: width: 360 }} 360w,{%- endif -%}
                          {%- if section.settings.main_left_image.width >= 533 -%}{{ section.settings.main_left_image | image_url: width: 533 }} 533w,{%- endif -%}
                          {%- if section.settings.main_left_image.width >= 720 -%}{{ section.settings.main_left_image | image_url: width: 720 }} 720w,{%- endif -%}
                          {%- if section.settings.main_left_image.width >= 940 -%}{{ section.settings.main_left_image | image_url: width: 940 }} 940w,{%- endif -%}
                          {%- if section.settings.main_left_image.width >= 1066 -%}{{ section.settings.main_left_image | image_url: width: 1066 }} 1066w,{%- endif -%}
                          {{ section.settings.main_left_image | image_url }} {{ section.settings.main_left_image.width }}w
                          "
                          src="{{ section.settings.main_left_image | image_url: width: 533 }}"
                          alt="{{ section.settings.main_left_image.alt | escape }}"
                          class="img-fluid main-left-img"
                          loading="lazy"
                          width="{{ section.settings.main_left_image.width }}"
                          height="{{ section.settings.main_left_image.height }}"
                    >
                {% endif %}            

            <div class="main-bag-buttons-wrap">
            {% for block in section.blocks %}
              {% if block.type == 'main_bag_btn' %}
                <a class="main-bag-btn-wrap" href="{{ block.settings.bag_btn_link }}">
                {% if block.settings.main_bag_btn != blank %}
                    <img
                          srcset="
                          {%- if block.settings.main_bag_btn.width >= 165 -%}{{ block.settings.main_bag_btn | image_url: width: 165 }} 165w,{%- endif -%}
                          {%- if block.settings.main_bag_btn.width >= 360 -%}{{ block.settings.main_bag_btn | image_url: width: 360 }} 360w,{%- endif -%}
                          {%- if block.settings.main_bag_btn.width >= 533 -%}{{ block.settings.main_bag_btn | image_url: width: 533 }} 533w,{%- endif -%}
                          {%- if block.settings.main_bag_btn.width >= 720 -%}{{ block.settings.main_bag_btn | image_url: width: 720 }} 720w,{%- endif -%}
                          {%- if block.settings.main_bag_btn.width >= 940 -%}{{ block.settings.main_bag_btn | image_url: width: 940 }} 940w,{%- endif -%}
                          {%- if block.settings.main_bag_btn.width >= 1066 -%}{{ block.settings.main_bag_btn | image_url: width: 1066 }} 1066w,{%- endif -%}
                          {{ block.settings.main_bag_btn | image_url }} {{ block.settings.main_bag_btn.width }}w
                          "
                          src="{{ block.settings.main_bag_btn | image_url: width: 533 }}"
                          alt="{{ block.settings.main_bag_btn.alt | escape }}"
                          class="img-fluid main-bag-btn {{forloop.index}}-btn"
                          loading="lazy"
                          width="{{ block.settings.main_bag_btn.width }}"
                          height="{{ block.settings.main_bag_btn.height }}"
                    >
                {% endif %}
            </a>
            {% endif %}
            {% endfor %}

            </div>
            </div>
        </div>

        <div class="right-content-part">
          <div class="right-main-heading">
            {{ section.settings.right_main_heading }}
          </div>
            <div class="right-main-subheading">
            {{ section.settings.right_main_subheading }}
          </div>
          <div class="right-main-dec">
            {{ section.settings.right_main_dec }}
          </div>
          </div>
        </div>
    </div>
  </div>

{%- comment -%}
  Sticky CTA buttons live in the separate `wyms-sticky-btns-section`.
  The `main_btns` block type is declared in that section's schema, not here.
{%- endcomment -%}
</div>



<style>

    .wyms-ergonomic-bag-section .first-section { padding-top: {{ section.settings.padding_top_desktop }}px; padding-bottom: {{ section.settings.padding_bottom_desktop }}px; }
    .wyms-ergonomic-bag-section { overflow: visible !important; }
    .wyms-ergonomic-bag-section img.img-fluid { height: auto; width: 100%; display: block; }
    .wyms-ergonomic-bag-section .first-left-part, .wyms-ergonomic-bag-section .right-content-part { width: 50%; }
    .wyms-ergonomic-bag-section .first-section, .wyms-ergonomic-bag-section .main-image { background-size: cover; background-position: center; background-repeat: no-repeat; }
    .wyms-ergonomic-bag-section img.img-fluid.main-bag-btn { height: 50px; width: 50px; object-fit: contain; }
    .wyms-ergonomic-bag-section .first-left-right-parts { display: flex; align-items: center; justify-content: center; gap: 24px; margin-bottom: -5%; padding-bottom: 96px; }
    .wyms-ergonomic-bag-section .right-main-heading { font-family: var(--font-family-display); color: #191839; font-size: 48px; font-style: normal; font-weight: 600; line-height: 60px; letter-spacing: -0.96px; }
    .wyms-ergonomic-bag-section .right-main-subheading { font-family: var(--font-family-highlights); font-size: 24px; font-weight: 400; line-height: 32px; padding-top: 24px; padding-bottom: 24px; color: #191839; }
    .wyms-ergonomic-bag-section .main-image { position: relative; }
    .wyms-ergonomic-bag-section .main-bag-btn-wrap img { transition: transform 0.3s ease; }
    .wyms-ergonomic-bag-section .main-bag-btn-wrap img:hover { transform: scale(1.09) }
    .main-bag-buttons-wrap .main-bag-btn-wrap:first-child img.main-bag-btn { position: absolute; top: 26%; left: 36%; }
    .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(2) img.main-bag-btn { position: absolute; left: 59%; top: 42%; }
    .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(3) img.main-bag-btn { position: absolute; left: 28%; top: 54%; }
    .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(4) img.main-bag-btn { position: absolute; left: 57%; top: 71%; }
    .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(5) img.main-bag-btn { position: absolute; left: 41%; top: 65%; }
    .wyms-ergonomic-bag-section .right-main-dec { font-family: var(--font-family-body, "Inter"); font-size: 16px; font-weight: 400; line-height: 24px; color: #191839; }

@media (max-width: 1599.98px) {
  .wyms-ergonomic-bag-section .first-section { padding-top: {{ section.settings.padding_top_laptop }}px; padding-bottom: {{ section.settings.padding_bottom_laptop }}px; }
}

@media (max-width: 991.98px) { 
  .wyms-ergonomic-bag-section .first-section { padding-top: {{ section.settings.padding_top_tablet }}px; padding-bottom: {{ section.settings.padding_bottom_tablet }}px; }
  .wyms-ergonomic-bag-section img.img-fluid.main-bag-btn { height: 43px; width: 43px; }
}

@media (max-width: 767.98px) {
  .wyms-ergonomic-bag-section .first-section { padding-top: {{ section.settings.padding_top_mobile }}px; padding-bottom: {{ section.settings.padding_bottom_mobile }}px; }
  .wyms-ergonomic-bag-section .right-main-heading { font-size: 30px; line-height: 44px; }
  .wyms-ergonomic-bag-section .right-main-subheading { padding-top: 20px; }
  .wyms-ergonomic-bag-section .first-left-right-parts { flex-direction: column; margin-bottom: 0%; }
  .wyms-ergonomic-bag-section .first-left-part, .wyms-ergonomic-bag-section .right-content-part { width: 100%; }
  .wyms-ergonomic-bag-section .right-content-part { order: -1; }
  .wyms-ergonomic-bag-section img.img-fluid.main-bag-btn { height: auto; width: 28px; }

} 

@media (max-width: 575.98px) { 
  .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(2) img.main-bag-btn { left: 65%; top: 38%; }
  .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(5) img.main-bag-btn { left: 36%; top: 74%; }
  .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(3) img.main-bag-btn { left: 26%; }
  .main-bag-buttons-wrap .main-bag-btn-wrap:nth-child(4) img.main-bag-btn { left: 62%; top: 67%; }
}


</style>




{% schema %}
{
  "name": "Bag Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "first_bg_image",
      "label": "First BG Image"
    },
    {
      "type": "image_picker",
      "id": "main_left_image",
      "label": "Add Left IMG"
    },
    {
      "type": "text",
      "id": "right_main_heading",
      "label": "Add Heading"
    },
    {
      "type": "textarea",
      "id": "right_main_subheading",
      "label": "Add Sub-Heading"
    },
    {
      "type": "textarea",
      "id": "right_main_dec",
      "label": "Add Description"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 110,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 110,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Laptop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_laptop",
      "label": "Padding Top (Laptop)",
      "default": 80,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_laptop",
      "label": "Padding Bottom (Laptop)",
      "default": 80,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Tablet Padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "main_bag_btn",
      "name": "Main Bag Btn",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "main_bag_btn",
          "label": "Bag Image"
        },
        {
          "type": "url",
          "id": "bag_btn_link",
          "label": "IMG Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bag Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}