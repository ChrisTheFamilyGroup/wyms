      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "main_bag_btn",
      "name": "Main Bag Btn",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "main_bag_btn",
          "label": "Bag Image"
        },
        {
          "type": "url",
          "id": "bag_btn_link",
          "label": "IMG Button Link"
        },
      ]
    },
  ],
  "presets": [
    {
      "name": "Bag Section",
      "category": "Custom"
    }
  ]
}
