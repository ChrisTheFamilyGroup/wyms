      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
