{{ 'wyms-collection-nav.css' | asset_url | stylesheet_tag }}
<script src="{{ 'wyms-collection-nav.js' | asset_url }}" defer="defer"></script>

<wyms-collection-nav class="collection-nav section-{{ section.id }}">
  <div class="collection-nav__outer page-width">
    
    <div class="collection-nav__inner">
      
      <div class="collection-nav__blobs">
        <picture class="collection-nav__blob collection-nav__blob--left">
          {%- if section.settings.blob_left_wide != blank -%}
            <source media="(min-width: 1441px)" srcset="{{ section.settings.blob_left_wide | image_url: width: 800 }}">
          {%- endif -%}
          {%- if section.settings.blob_left_desktop != blank -%}
            <source media="(min-width: 769px)" srcset="{{ section.settings.blob_left_desktop | image_url: width: 600 }}">
          {%- endif -%}
          {%- if section.settings.blob_left_mobile != blank -%}
            <img src="{{ section.settings.blob_left_mobile | image_url: width: 400 }}" width="" height="" alt="" loading="lazy">
          {%- endif -%}
        </picture>

        <picture class="collection-nav__blob collection-nav__blob--right">
          {%- if section.settings.blob_right_wide != blank -%}
            <source media="(min-width: 1441px)" srcset="{{ section.settings.blob_right_wide | image_url: width: 800 }}">
          {%- endif -%}
          {%- if section.settings.blob_right_desktop != blank -%}
            <source media="(min-width: 769px)" srcset="{{ section.settings.blob_right_desktop | image_url: width: 600 }}">
          {%- endif -%}
          {%- if section.settings.blob_right_mobile != blank -%}
            <img src="{{ section.settings.blob_right_mobile | image_url: width: 400 }}" width="" height="" alt="" loading="lazy">
          {%- endif -%}
        </picture>
      </div>

      <div class="collection-nav__content">
        
        <div class="collection-nav__text-block">
          {%- if section.settings.title != blank -%}
            <h1 class="collection-nav__title">{{ section.settings.title }}</h1>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="collection-nav__desc">{{ section.settings.description }}</p>
          {%- endif -%}
        </div>

        <div class="collection-nav__buttons-wrapper">
          <div class="collection-nav__buttons">
            {%- for block in section.blocks -%}
              {%- if block.type == 'nav_button' -%}
                
                {%- liquid
                  assign is_active = false
                  if request.path == block.settings.link
                    assign is_active = true
                  endif
                -%}

                <a href="{{ block.settings.link | default: '#' }}" 
                   class="collection-nav__btn {% if is_active %}is-active{% endif %}"
                   {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 40 | image_tag: class: 'collection-nav__btn-icon', loading: 'lazy' }}
                  {%- endif -%}
                  {%- if block.settings.label != blank -%}
                    <span class="collection-nav__btn-text">{{ block.settings.label }}</span>
                  {%- endif -%}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      </div>

    </div>
  </div>
</wyms-collection-nav>

{% schema %}
{
  "name": "Collection Navigation",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Unsere Rucksäcke"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Entdecke unsere Kollektion an ergonomischen Schulrucksäcken."
    },
    {
      "type": "header",
      "content": "Left Background Blob"
    },
    {
      "type": "image_picker",
      "id": "blob_left_desktop",
      "label": "Desktop Image (769px - 1440px)"
    },
    {
      "type": "image_picker",
      "id": "blob_left_wide",
      "label": "Wide Image (> 1440px)"
    },
    {
      "type": "image_picker",
      "id": "blob_left_mobile",
      "label": "Mobile Image (< 768px)"
    },
    {
      "type": "header",
      "content": "Right Background Blob"
    },
    {
      "type": "image_picker",
      "id": "blob_right_desktop",
      "label": "Desktop Image (769px - 1440px)"
    },
    {
      "type": "image_picker",
      "id": "blob_right_wide",
      "label": "Wide Image (> 1440px)"
    },
    {
      "type": "image_picker",
      "id": "blob_right_mobile",
      "label": "Mobile Image (< 768px)"
    }
  ],
  "blocks": [
    {
      "type": "nav_button",
      "name": "Navigation Button",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Button Icon (20x20)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Active state depends on this link matching the current page URL."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Navigation",
      "blocks": [
        { "type": "nav_button" },
        { "type": "nav_button" },
        { "type": "nav_button" }
      ]
    }
  ]
}
{% endschema %}