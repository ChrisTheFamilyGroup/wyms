{{ 'wyms-collection-nav.css' | asset_url | stylesheet_tag }}
<script src="{{ 'wyms-collection-nav.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }} .collection-nav__inner {
    background-color: {{ section.settings.bg_color }} !important;
  }

  .section-{{ section.id }} .collection-nav__title {
    color: {{ section.settings.color_title }} !important;
  }

  .section-{{ section.id }} .collection-nav__desc,
  .section-{{ section.id }} .collection-nav__desc p,
  .section-{{ section.id }} p.collection-nav__desc {
    color: {{ section.settings.color_desc }} !important;
  }

  .section-{{ section.id }} .collection-nav__btn {
    background-color: {{ section.settings.color_btn_bg }} !important;
  }

  .section-{{ section.id }} .collection-nav__btn-text {
    color: {{ section.settings.color_btn_text }} !important;
  }

  .section-{{ section.id }} .collection-nav__btn svg path {
    stroke: {{ section.settings.color_btn_text }} !important;
  }

  .section-{{ section.id }} .collection-nav__btn.is-active,
  .section-{{ section.id }} .collection-nav__btn:hover {
    background-color: {{ section.settings.color_btn_bg_active }} !important;
  }
{%- endstyle -%}

<wyms-collection-nav class="collection-nav section-{{ section.id }}">
  <div class="collection-nav__outer page-width">
    <div class="collection-nav__inner">
      
      <div class="collection-nav__blobs">
        {%- liquid
          assign full_bg_exists = false
          if section.settings.full_bg_desktop != blank or section.settings.full_bg_mobile != blank
            assign full_bg_exists = true
          endif
        -%}

        {%- if full_bg_exists -%}
          <picture class="collection-nav__full-bg">
            {%- if section.settings.full_bg_wide != blank -%}
              <source media="(min-width: 1441px)" srcset="{{ section.settings.full_bg_wide | image_url: width: 2000 }}">
            {%- endif -%}
            {%- if section.settings.full_bg_desktop != blank -%}
              <source media="(min-width: 769px)" srcset="{{ section.settings.full_bg_desktop | image_url: width: 1600 }}">
            {%- endif -%}
            <img src="{{ section.settings.full_bg_mobile | default: section.settings.full_bg_desktop | image_url: width: 800 }}" 
                 alt="" width="" height="" loading="lazy" class="full-bg-img">
          </picture>

        {%- else -%}
          <picture class="collection-nav__blob collection-nav__blob--left">
            {%- if section.settings.blob_left_wide != blank -%}
              <source media="(min-width: 1441px)" srcset="{{ section.settings.blob_left_wide | image_url: width: 800 }}">
            {%- endif -%}
            {%- if section.settings.blob_left_desktop != blank -%}
              <source media="(min-width: 769px)" srcset="{{ section.settings.blob_left_desktop | image_url: width: 600 }}">
            {%- endif -%}
            {%- if section.settings.blob_left_mobile != blank -%}
              <img src="{{ section.settings.blob_left_mobile | image_url: width: 400 }}" alt="" width="" height="" loading="lazy">
            {%- endif -%}
          </picture>

          <picture class="collection-nav__blob collection-nav__blob--right">
            {%- if section.settings.blob_right_wide != blank -%}
              <source media="(min-width: 1441px)" srcset="{{ section.settings.blob_right_wide | image_url: width: 800 }}">
            {%- endif -%}
            {%- if section.settings.blob_right_desktop != blank -%}
              <source media="(min-width: 769px)" srcset="{{ section.settings.blob_right_desktop | image_url: width: 600 }}">
            {%- endif -%}
            {%- if section.settings.blob_right_mobile != blank -%}
              <img src="{{ section.settings.blob_right_mobile | image_url: width: 400 }}" alt="" width="" height="" loading="lazy">
            {%- endif -%}
          </picture>
        {%- endif -%}
      </div>

      <div class="collection-nav__content">
        <div class="collection-nav__text-block">
          {%- if section.settings.title != blank -%}
            <h1 class="collection-nav__title">{{ section.settings.title }}</h1>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <div class="collection-nav__desc">{{ section.settings.description }}</div>
          {%- endif -%}
        </div>

        <div class="collection-nav__buttons-wrapper" data-wyms-scroll-track>
          <div class="collection-nav__buttons">
            {%- for block in section.blocks -%}
              {%- if block.type == 'nav_button' -%}
                {%- liquid
                  assign is_active = false
                  if request.path == block.settings.link
                    assign is_active = true
                  endif
                -%}
                <a href="{{ block.settings.link | default: '#' }}" 
                   class="collection-nav__btn {% if is_active %}is-active{% endif %}"
                   {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 40 | image_tag: class: 'collection-nav__btn-icon', loading: 'lazy' }}
                  {%- endif -%}
                  {%- if block.settings.label != blank -%}
                    <span class="collection-nav__btn-text">{{ block.settings.label }}</span>
                  {%- endif -%}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    </div>
  </div>
</wyms-collection-nav>

{% schema %}
{
  "name": "Collection Navigation",
  "settings": [
    {
      "type": "header",
      "content": "Appearance & Colors"
    },
    { "type": "color", "id": "bg_color", "label": "Inner Background Color", "default": "#6865EA" },
    { "type": "color", "id": "color_title", "label": "Heading Color", "default": "#FFFFFF" },
    { "type": "color", "id": "color_desc", "label": "Description Color", "default": "#FFFFFF" },
    { "type": "color", "id": "color_btn_bg", "label": "Button Background (Default)", "default": "rgba(25, 24, 57, 0.20)" },
    { "type": "color", "id": "color_btn_bg_active", "label": "Button Background (Active/Hover)", "default": "#242352" },
    { "type": "color", "id": "color_btn_text", "label": "Button Text Color", "default": "#FFFFFF" },
    {
      "type": "header",
      "content": "Full Background Image (Priority)"
    },
    { "type": "image_picker", "id": "full_bg_wide", "label": "Full Background Wide (>1440px)" },
    { "type": "image_picker", "id": "full_bg_desktop", "label": "Full Background Desktop" },
    { "type": "image_picker", "id": "full_bg_mobile", "label": "Full Background Mobile" },
    {
      "type": "header",
      "content": "Text Content"
    },
    { "type": "text", "id": "title", "label": "Heading", "default": "Unsere Rucksäcke" },
    { "type": "textarea", "id": "description", "label": "Description" },
    {
      "type": "header",
      "content": "Fallback: Blobs (Left & Right)"
    },
    { "type": "image_picker", "id": "blob_left_desktop", "label": "Left Blob (Desktop)" },
    { "type": "image_picker", "id": "blob_left_wide", "label": "Left Blob (Wide)" },
    { "type": "image_picker", "id": "blob_left_mobile", "label": "Left Blob (Mobile)" },
    { "type": "image_picker", "id": "blob_right_desktop", "label": "Right Blob (Desktop)" },
    { "type": "image_picker", "id": "blob_right_wide", "label": "Right Blob (Wide)" },
    { "type": "image_picker", "id": "blob_right_mobile", "label": "Right Blob (Mobile)" }
  ],
  "blocks": [
    {
      "type": "nav_button",
      "name": "Navigation Button",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "label", "label": "Label", "default": "Category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Collection Navigation" }]
}
{% endschema %}