{{ 'wyms-two-images-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_content = false
  if section.settings.heading != blank or section.settings.body_text != blank or section.settings.image_left != blank
    assign has_content = true
  endif
-%}

{%- if has_content or request.design_mode -%}
  <section class="wyms-two-images-text">
    
    {%- if has_content == false and request.design_mode -%}
      <div class="wyms-two-images-text__empty-state">
        <h3>Two Images with Text section is empty</h3>
        <p>Please add content or images in the section settings to display it on the storefront.</p>
      </div>
    {%- else -%}

      <div class="wyms-two-images-text__inner page-width">
        
        <!-- Left Column: Images -->
        <div class="wyms-two-images-text__images">
          
          <div class="wyms-two-images-text__img-wrapper wyms-two-images-text__img-wrapper--left">
            {%- if section.settings.image_left != blank -%}
              <img src="{{ section.settings.image_left | image_url: width: 800 }}" 
                   alt="{{ section.settings.heading | escape }}" 
                   class="wyms-two-images-text__img" 
                   loading="lazy"
                   width="{{ section.settings.image_left.width }}"
                   height="{{ section.settings.image_left.height }}">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg wyms-two-images-text__img' }}
            {%- endif -%}
          </div>

          <div class="wyms-two-images-text__img-wrapper wyms-two-images-text__img-wrapper--right">
            {%- if section.settings.image_right != blank -%}
              <img src="{{ section.settings.image_right | image_url: width: 1000 }}" 
                   alt="{{ section.settings.heading | escape }}" 
                   class="wyms-two-images-text__img" 
                   loading="lazy"
                   width="{{ section.settings.image_right.width }}"
                   height="{{ section.settings.image_right.height }}">
            {%- else -%}
              {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg wyms-two-images-text__img' }}
            {%- endif -%}
          </div>

        </div>

        <!-- Right Column: Text Content -->
        <div class="wyms-two-images-text__content">
          
          {%- if section.settings.heading != blank -%}
            <h2 class="wyms-two-images-text__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          <div class="wyms-two-images-text__desc-block">
            {%- if section.settings.body_text != blank -%} <div class="wyms-two-images-text__body"> {{ section.settings.body_text }}</div>
            {%- endif -%}

            {%- if section.settings.bottom_body_text != blank -%} <div class="wyms-two-images-text__bottom_body_text"> {{ section.settings.bottom_body_text }}</div>
            {%- endif -%}

            {%- if section.settings.highlight_text != blank -%}
              <div class="wyms-two-images-text__highlight"> {{ section.settings.highlight_text }}</div>
            {%- endif -%}
          </div>

        </div>

      </div>

    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "WYMS Two Images & Text",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Body Text"
    },
    {
      "type": "textarea",
      "id": "bottom_body_text",
      "label": "Bottom Body Text",
      "default": "Bottom Body Text"
    },
    {
      "type": "textarea",
      "id": "highlight_text",
      "label": "Bottom Highlight Text",
      "default": "Bottom Highlight Text"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left Image (Square)"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right Image (Vertical)"
    }
  ],
  "presets": [
    {
      "name": "WYMS Two Images & Text"
    }
  ]
}
{% endschema %}