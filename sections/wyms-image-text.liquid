{{ 'wyms-image-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_content = false
  if section.settings.heading != blank or section.settings.image != blank
    assign has_content = true
  endif
-%}

{%- if has_content or request.design_mode -%}
  {%- style -%}
    #shopify-section-{{ section.id }} {
      --icon-width: {{ section.settings.icon_width }}px;
      --icon-width-mobile: {{ section.settings.icon_width_mobile }}px;
      --icon-top-desktop: {{ section.settings.icon_top_desktop }}%;
      --icon-right-desktop: {{ section.settings.icon_right_desktop }}%;
      --icon-top-wide: {{ section.settings.icon_top_wide }}%;
      --icon-right-wide: {{ section.settings.icon_right_wide }}%;
      --icon-top-mobile: {{ section.settings.icon_top_mobile }}%;
      --icon-right-mobile: {{ section.settings.icon_right_mobile }}%;
    }
  {%- endstyle -%}

  <section class="wyms-image-text">
    
    {%- if has_content == false and request.design_mode -%}
      <div style="padding: 40px; text-align: center; border: 2px dashed #ccc; background: #f9f9f9; width: 100%; z-index: 10; position: relative;">
        <h3>Image with Text section is empty</h3>
        <p>Please add a heading or an image in the section settings to display it on the storefront.</p>
      </div>
    {%- else -%}

      <!-- Background Blob -->
      {%- if section.settings.bg_blob != blank -%}
        <img src="{{ section.settings.bg_blob | image_url: width: 900 }}" 
             alt="" 
             class="wyms-image-text__blob" 
             loading="lazy"
             width="{{ section.settings.bg_blob.width }}"
             height="{{ section.settings.bg_blob.height }}">
      {%- endif -%}

      <!-- Main Content Container -->
      <div class="wyms-image-text__container">
        
        <!-- Left Column: Text Content -->
        <div class="wyms-image-text__content">
          {%- if section.settings.heading != blank -%}
            <h2 class="wyms-image-text__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.top_text != blank -%}
            <div class="wyms-image-text__top-body">{{ section.settings.top_text }}</div>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="wyms-image-text__body">{{ section.settings.text }}</div>
          {%- endif -%}

          {%- if section.settings.bottom_text != blank -%}
            <div class="wyms-image-text__bottom-body">{{ section.settings.bottom_text }}</div>
          {%- endif -%}

          {%- if section.settings.highlight_text != blank -%}
            <div class="wyms-image-text__highlight">{{ section.settings.highlight_text }}</div>
          {%- endif -%}

          <!-- NEW: Checkmark List Block -->
          {%- if section.blocks.size > 0 -%}
            <div class="wyms-image-text__list">
              {%- for block in section.blocks -%}
                <div class="wyms-image-text__list-item" {{ block.shopify_attributes }}>
                  <div class="wyms-image-text__list-icon">
                    {%- if block.settings.icon != blank -%}
                      <img src="{{ block.settings.icon | image_url: width: 48 }}" 
                           alt="icon" 
                           loading="lazy"
                           width="{{ block.settings.icon.width }}"
                           height="{{ block.settings.icon.height }}">
                    {%- endif -%}
                  </div>
                  <div class="wyms-image-text__list-text">{{ block.settings.text }} </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

      
        <div class="wyms-image-text__media">
          
          <!-- Floating Icon -->
          {%- if section.settings.floating_icon != blank -%}
            <img src="{{ section.settings.floating_icon | image_url: width: 300 }}" 
                 alt="" 
                 class="wyms-image-text__floating-icon" 
                 loading="lazy"
                 width="{{ section.settings.floating_icon.width }}"
                 height="{{ section.settings.floating_icon.height }}">
          {%- endif -%}

          <!-- Main Image -->
          {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | image_url: width: 1200 }}" 
                 alt="{{ section.settings.heading | escape }}" 
                 class="wyms-image-text__img" 
                 loading="lazy"
                 width="{{ section.settings.image.width }}"
                 height="{{ section.settings.image.height }}">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg wyms-image-text__img' }}
          {%- endif -%}
        </div>

      </div>

    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "WYMS Image with Text",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "textarea",
      "id": "top_text",
      "label": "Top Body Text",
      "default": "Top Body Text"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Body Text"
    },
    {
      "type": "textarea",
      "id": "bottom_text",
      "label": "Bottom Body Text",
      "default": "Bottom Body Text"
    },
    {
      "type": "textarea",
      "id": "highlight_text",
      "label": "Bottom Highlight Text",
      "default": "Bottom Highlight Text"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "bg_blob",
      "label": "Background Blob"
    },
    {
      "type": "header",
      "content": "Floating Icon (On Image)"
    },
    {
      "type": "image_picker",
      "id": "floating_icon",
      "label": "Icon Image"
    },
    {
      "type": "range",
      "id": "icon_width",
      "min": 20,
      "max": 300,
      "step": 4,
      "unit": "px",
      "label": "Icon Width",
      "default": 80
    },
    {
      "type": "paragraph",
      "content": "--- Desktop Positioning ---"
    },
    {
      "type": "range",
      "id": "icon_top_desktop",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Top Offset (%)",
      "default": 0
    },
    {
      "type": "range",
      "id": "icon_right_desktop",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Right Offset (%)",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "--- Wide Screens (1440px+) ---"
    },
    {
      "type": "range",
      "id": "icon_top_wide",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Top Offset (%)",
      "default": 0
    },
    {
      "type": "range",
      "id": "icon_right_wide",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Right Offset (%)",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "--- Mobile Positioning ---"
    },
    {
      "type": "range",
      "id": "icon_width_mobile",
      "min": 80,
      "max": 180,
      "step": 1,
      "unit": "px",
      "label": "Icon Width (Mobile)",
      "default": 80
    },
    {
      "type": "range",
      "id": "icon_top_mobile",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Top Offset (%)",
      "default": 0
    },
    {
      "type": "range",
      "id": "icon_right_mobile",
      "min": -50,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "Right Offset (%)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (Checkmark)"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "List item text goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WYMS Image with Text",
      "blocks": [
        { "type": "list_item" },
        { "type": "list_item" },
        { "type": "list_item" }
      ]
    }
  ]
}
{% endschema %}