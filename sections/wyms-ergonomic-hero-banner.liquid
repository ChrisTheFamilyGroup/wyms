<div class="wyms-ergonomic-hero-banner">
  <div class="bg-bag-wrapper" style="background-image: url({{ section.settings.main_bg_image | image_url: width: 2000 }});">
    <div class="page-width">

    {% for block in section.blocks %}
    <div class="second-section-img-content block-{{ forloop.index }} {% if block.settings.reverse_layout %}reverse{% endif %}">
      <div class="sec-content-part">

        {% if block.settings.first_img != blank %}
            <div class="first-img-wrap">
        <img
          srcset="
            {%- if block.settings.first_img.width >= 165 -%}{{ block.settings.first_img | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if block.settings.first_img.width >= 360 -%}{{ block.settings.first_img | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if block.settings.first_img.width >= 533 -%}{{ block.settings.first_img | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if block.settings.first_img.width >= 720 -%}{{ block.settings.first_img | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if block.settings.first_img.width >= 940 -%}{{ block.settings.first_img | image_url: width: 940 }} 940w,{%- endif -%}
            {%- if block.settings.first_img.width >= 1066 -%}{{ block.settings.first_img | image_url: width: 1066 }} 1066w,{%- endif -%}
            {{ block.settings.first_img | image_url }} {{ block.settings.first_img.width }}w
          "
          src="{{ block.settings.first_img | image_url: width: 533 }}"
          alt="{{ block.settings.first_img.alt | escape }}"
          class="img-fluid first-img"
          loading="lazy"
          width="{{ block.settings.first_img.width }}"
          height="{{ block.settings.first_img.height }}"
        >
    </div>
    {% endif %}

    {% if block.settings.sec_img != blank %}
            <div class="sec-img-wrap">
        <img
          srcset="
            {%- if block.settings.sec_img.width >= 165 -%}{{ block.settings.sec_img | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if block.settings.sec_img.width >= 360 -%}{{ block.settings.sec_img | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if block.settings.sec_img.width >= 533 -%}{{ block.settings.sec_img | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if block.settings.sec_img.width >= 720 -%}{{ block.settings.sec_img | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if block.settings.sec_img.width >= 940 -%}{{ block.settings.sec_img | image_url: width: 940 }} 940w,{%- endif -%}
            {%- if block.settings.sec_img.width >= 1066 -%}{{ block.settings.sec_img | image_url: width: 1066 }} 1066w,{%- endif -%}
            {{ block.settings.sec_img | image_url }} {{ block.settings.sec_img.width }}w
          "
          src="{{ block.settings.sec_img | image_url: width: 533 }}"
          alt="{{ block.settings.sec_img.alt | escape }}"
          class="img-fluid sec-img"
          loading="lazy"
          width="{{ block.settings.sec_img.width }}"
          height="{{ block.settings.sec_img.height }}"
        >
    </div>
    {% endif %}

    {% if block.settings.third_img != blank %}
            <div class="third-img-wrap">
        <img
          srcset="
            {%- if block.settings.third_img.width >= 165 -%}{{ block.settings.third_img | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if block.settings.third_img.width >= 360 -%}{{ block.settings.third_img | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if block.settings.third_img.width >= 533 -%}{{ block.settings.third_img | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if block.settings.third_img.width >= 720 -%}{{ block.settings.third_img | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if block.settings.third_img.width >= 940 -%}{{ block.settings.third_img | image_url: width: 940 }} 940w,{%- endif -%}
            {%- if block.settings.third_img.width >= 1066 -%}{{ block.settings.third_img | image_url: width: 1066 }} 1066w,{%- endif -%}
            {{ block.settings.third_img | image_url }} {{ block.settings.third_img.width }}w
          "
          src="{{ block.settings.third_img | image_url: width: 533 }}"
          alt="{{ block.settings.third_img.alt | escape }}"
          class="img-fluid third-img"
          loading="lazy"
          width="{{ block.settings.third_img.width }}"
          height="{{ block.settings.third_img.height }}"
        >
    </div>
    {% endif %}

    <div class="heading-para-btn-wrap">
        <div class="sec-dec">
          {{ block.settings.sec_dec }}
        </div>
        <div class="sec-heading">
          {{ block.settings.sec_heading }}
        </div>

        {% if block.settings.sec_btn != blank %}
       <div class="sec-btn">

        <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %}
          class="btn-flygge btn--blue btn--xl" href="{{ block.settings.sec_btn_link }}"
          style="background-color: {{ block.settings.sec_btn_bg }} !important;
                  color: {{ block.settings.sec_btn_text }} !important;">
          <span class="hide-desktop">{{ block.settings.sec_btn }}</span>
          <span class="hide-mobile">{{ block.settings.sec_btn_mobile }}</span>
          {% render 'icon-sparkles' %}
        </a>
        
      </div>
      {% endif %}

        </div>

        {% if block.settings.last_img != blank %}
            <div class="last-img-wrap">
        <img
          srcset="
            {%- if block.settings.last_img.width >= 165 -%}{{ block.settings.last_img | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if block.settings.last_img.width >= 360 -%}{{ block.settings.last_img | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if block.settings.last_img.width >= 533 -%}{{ block.settings.last_img | image_url: width: 533 }} 533w,{%- endif -%}
            {%- if block.settings.last_img.width >= 720 -%}{{ block.settings.last_img | image_url: width: 720 }} 720w,{%- endif -%}
            {%- if block.settings.last_img.width >= 940 -%}{{ block.settings.last_img | image_url: width: 940 }} 940w,{%- endif -%}
            {%- if block.settings.last_img.width >= 1066 -%}{{ block.settings.last_img | image_url: width: 1066 }} 1066w,{%- endif -%}
            {{ block.settings.last_img | image_url }} {{ block.settings.last_img.width }}w
          "
          src="{{ block.settings.last_img | image_url: width: 533 }}"
          alt="{{ block.settings.last_img.alt | escape }}"
          class="img-fluid last-img"
          loading="lazy"
          width="{{ block.settings.last_img.width }}"
          height="{{ block.settings.last_img.height }}"
        >
    </div>
    {% endif %}
      </div>

      <div class="sec-img-part">
        {% if block.settings.featured_image != blank %}
          <img
            srcset="
              {%- if block.settings.featured_image.width >= 165 -%}{{ block.settings.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if block.settings.featured_image.width >= 360 -%}{{ block.settings.featured_image | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if block.settings.featured_image.width >= 533 -%}{{ block.settings.featured_image | image_url: width: 533 }} 533w,{%- endif -%}
              {%- if block.settings.featured_image.width >= 720 -%}{{ block.settings.featured_image | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if block.settings.featured_image.width >= 940 -%}{{ block.settings.featured_image | image_url: width: 940 }} 940w,{%- endif -%}
              {%- if block.settings.featured_image.width >= 1066 -%}{{ block.settings.featured_image | image_url: width: 1066 }} 1066w,{%- endif -%}
              {{ block.settings.featured_image | image_url }} {{ block.settings.featured_image.width }}w
            "
            src="{{ block.settings.featured_image | image_url: width: 533 }}"
            alt="{{ block.settings.featured_image.alt | escape }}"
            class="img-fluid featured-image"
            loading="lazy"
            width="{{ block.settings.featured_image.width }}"
            height="{{ block.settings.featured_image.height }}"
          >
        {% endif %}
      </div>
    </div>
    {% endfor %}

    </div>
  </div>
</div>

<style>
  .wyms-ergonomic-hero-banner { padding: 16px; }
  .wyms-ergonomic-hero-banner .bg-bag-wrapper { padding-top: {{ section.settings.padding_top_desktop }}px; padding-bottom: {{ section.settings.padding_bottom_desktop }}px; }
  .wyms-ergonomic-hero-banner h1, .wyms-ergonomic-hero-banner h2, .wyms-ergonomic-hero-banner h3, .wyms-ergonomic-hero-banner h4, .wyms-ergonomic-hero-banner h5, .wyms-ergonomic-hero-banner h6, .wyms-ergonomic-hero-banner p { padding: 0; margin: 0; }
  .wyms-ergonomic-hero-banner img.img-fluid { height: auto; width: 100%; display: block; }
  .wyms-ergonomic-hero-banner .first-img-wrap { position: absolute; right: 50%; top: -61%; }
  .wyms-ergonomic-hero-banner img.img-fluid.first-img { height: 60px; width: 60px; }
  .wyms-ergonomic-hero-banner .second-section-img-content { display: flex; align-items: center; justify-content: center; gap: 64px; }
  .wyms-ergonomic-hero-banner .sec-heading { color: #fff; font-family: var(--font-family-display); font-size: 60px; font-style: normal; font-weight: 600; line-height: 72px; letter-spacing: -1.2px; text-align: left; max-width: 100%; }
  .wyms-ergonomic-hero-banner .sec-btn a { text-decoration: none; padding: 12px 18px !important; text-align: center; display: inline-block; border-radius: var(--radius-full, 9999px); font-family: var(--Font-family-font-family-body, Inter); font-size: var(--Font-size-text-md, 16px); font-style: normal; font-weight: 600; line-height: var(--Line-height-text-md, 24px); }
  .wyms-ergonomic-hero-banner .sec-dec { color: #fff; font-family: var(--font-family-body); font-size: 20px; font-style: normal; font-weight: 400; line-height: 32px; padding-bottom: 16px; }
  .wyms-ergonomic-hero-banner .sec-dec p { padding-bottom: 20px; }
  .wyms-ergonomic-hero-banner .sec-dec p:last-child { padding-bottom: 0; }
  .wyms-ergonomic-hero-banner .sec-content-part, .wyms-ergonomic-hero-banner .sec-img-part { width: 50%; } {% comment %} { width: calc(50% - 32px); } {% endcomment %}
  .wyms-ergonomic-hero-banner .second-section-img-content.block-2 { padding-top: 64px; }
  .wyms-ergonomic-hero-banner .reverse { flex-direction: row-reverse; }
  .wyms-ergonomic-hero-banner .bg-bag-wrapper { background-size: cover; background-position: center; background-repeat: no-repeat; border-radius: 16px; background:#6865EA; }
  .wyms-ergonomic-hero-banner .second-section-img-content strong { font-family: var(--Font-family-font-family-highlights, "Concrette S"); font-size: var(--Font-size-display-xs, 24px); font-style: normal; font-weight: 350 !important; line-height: var(--Line-height-display-xs, 32px); }
  .hide-desktop { display: none; }
  .hide-mobile { display: inline-block; }
  .wyms-ergonomic-hero-banner .second-section-img-content.block-2.reverse img.img-fluid.first-img { height: 57px; width: 57px; }
  .wyms-ergonomic-hero-banner p:has(strong) { padding: 0 !important; }
  .wyms-ergonomic-hero-banner img.img-fluid.last-img { height: 320px; width: 320px; }
  .wyms-ergonomic-hero-banner .last-img-wrap { display: flex; justify-content: end; padding-top: 16px; }
  .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .sec-content-part { position: relative; z-index: 1; }
  .wyms-ergonomic-hero-banner .second-section-img-content.block-1 img.img-fluid.last-img { height: 280px; width: 280px; }
  .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { position: absolute; left: 0; bottom: 3%; z-index: -1; }
  .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .heading-para-btn-wrap { padding-left: 32px; }
  .wyms-ergonomic-hero-banner img.img-fluid.sec-img { height: 80px; width: 80px; object-fit: contain; }
  .wyms-ergonomic-hero-banner .sec-img-wrap { position: absolute; right: -15%; top: -37%; }
  .wyms-ergonomic-hero-banner img.img-fluid.third-img { height: 70px; width: 70px; object-fit: contain; display: none; }

  .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap .img-fluid.last-img { border-radius: 50%; animation: steerLoop 3s ease-in-out infinite; }

  @keyframes steerLoop {
    0%   { transform: rotate(0deg); }
    33%  { transform: rotate(-180deg); }
    66%  { transform: rotate(0deg); }
    100% { transform: rotate(0deg); }
  }




  .wyms-ergonomic-hero-banner .second-section-img-content.block-2 .heading-para-btn-wrap { padding-right: 64px; }





  @media (max-width: 1599.98px) {
    .wyms-ergonomic-hero-banner .bg-bag-wrapper { padding-top: {{ section.settings.padding_top_laptop }}px; padding-bottom: {{ section.settings.padding_bottom_laptop }}px; }
    .wyms-ergonomic-hero-banner .sec-img-wrap { right: -5%; }
  }
  @media (max-width: 1550.98px) {
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: 14%; }
  }
  @media (max-width: 1440.98px) {
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: 10%; }
    .wyms-ergonomic-hero-banner img.img-fluid.third-img { display: block !important; }
    .wyms-ergonomic-hero-banner .third-img-wrap { position: absolute; bottom: -50%; right: 28%; }
  }
  @media (max-width: 1399.98px) {
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: 2%; }
    .wyms-ergonomic-hero-banner .sec-heading { font-size: 55px; }
  }

  @media (max-width: 1299.98px) {
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: -3%; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 img.img-fluid.last-img { height: 240px; width: 240px; }
  }
  @media (max-width: 1266.98px) {
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: -8%; }
  }
  @media (max-width: 1199.98px) {
    .wyms-ergonomic-hero-banner .sec-heading { font-size: 48px; line-height: normal; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: -8%; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 img.img-fluid.last-img { height: 200px; width: 200px; }
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -42%; right: 26%; }
    .wyms-ergonomic-hero-banner .sec-heading br { display: none; }
    .wyms-ergonomic-hero-banner .first-img-wrap { right: 45%; top: -50%; }
    .wyms-ergonomic-hero-banner .sec-img-wrap { top: -25%; }
  }

  @media (max-width: 1099.98px) {
    .wyms-ergonomic-hero-banner .first-img-wrap { top: -40%; }
  }

  @media (max-width: 991.98px) {
    .wyms-ergonomic-hero-banner .bg-bag-wrapper { padding-top: {{ section.settings.padding_top_tablet }}px; padding-bottom: {{ section.settings.padding_bottom_tablet }}px; }
    .wyms-ergonomic-hero-banner .sec-dec p { padding-bottom: 8px; }
    .main-spin-wrap { margin-top: 0; }
    .wyms-ergonomic-hero-banner .first-img-wrap { top: -30%; }
    .wyms-ergonomic-hero-banner .sec-img-wrap { top: -10%; }
    .wyms-ergonomic-hero-banner img.img-fluid.third-img { height: 60px; width: 60px; }
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -32%; right: 24%; }
    .wyms-ergonomic-hero-banner .sec-heading { font-size: 43px; }

  }

  @media (max-width: 840.98px) {
    .wyms-ergonomic-hero-banner .second-section-img-content { padding-top: 50px; }
  }

  @media (max-width: 767.98px) {
    .wyms-ergonomic-hero-banner .bg-bag-wrapper { padding-top: {{ section.settings.padding_top_mobile }}px; padding-bottom: {{ section.settings.padding_bottom_mobile }}px; }
    .wyms-ergonomic-hero-banner .second-section-img-content { flex-direction: column; }
    .wyms-ergonomic-hero-banner .sec-content-part, .wyms-ergonomic-hero-banner .sec-img-part { width: 100%; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-2.reverse .sec-content-part { order: 2; }
    .wyms-ergonomic-hero-banner img.img-fluid.last-img { width: 280px; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 img.img-fluid.last-img { height: 270px; width: 270px; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-2.reverse { gap: 0; }
    .wyms-ergonomic-hero-banner img.img-fluid.last-img { width: 100%; height: auto; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-2.reverse .last-img-wrap { padding-left: 40px; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-2 .heading-para-btn-wrap { padding-right: 0; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .heading-para-btn-wrap { padding-left: 0; }
    .wyms-ergonomic-hero-banner .second-section-img-content { gap: 0; }
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -375%; right: 85%; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .sec-content-part { margin-bottom: 0; }
    .wyms-ergonomic-hero-banner .sec-img-wrap { top: 100%; right: 2%; }
    .wyms-ergonomic-hero-banner .first-img-wrap { top: 98%; right: unset; left: 2%; }
    .wyms-ergonomic-hero-banner { padding: 8px; }
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .sec-content-part { order: 2; }

  }
  @media screen and (max-width: 768px) {
    .hide-mobile { display: none !important; }
    .hide-desktop { display: block !important; }
  }

  @media (max-width: 699px) {
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -290%; right: 87%; }
    {% comment %} .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .sec-content-part { margin-bottom: -20%; } {% endcomment %}
}

  @media screen and (max-width: 575px) {
    .wyms-ergonomic-hero-banner .sec-heading { font-size: 48px; }
  }

  @media (max-width: 571px) {
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -149%; }
  }

  @media screen and (max-width: 450px) {
    .wyms-ergonomic-hero-banner .second-section-img-content.block-1 .last-img-wrap { bottom: -2%; }
    .wyms-ergonomic-hero-banner .first-img-wrap { top: 90%; }
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -189%; right: 43%; }
    .wyms-ergonomic-hero-banner .sec-dec p, .wyms-ergonomic-hero-banner .sec-heading { text-align: left; }
    .wyms-ergonomic-hero-banner .second-section-img-content { padding-top: 70px; }
    }

    @media screen and (max-width: 420px) {
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -167%; }
    }

    @media screen and (max-width: 414px) {
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -129%; }
    }
    @media screen and (max-width: 370px) {
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -115%; }
    }
    @media screen and (max-width: 340px) {
    .wyms-ergonomic-hero-banner .third-img-wrap { bottom: -110%; }
}

</style>


{% schema %}
{
  "name": "Ergonomic Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_bg_image",
      "label": "Main BG Image"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Laptop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_laptop",
      "label": "Padding Top (Laptop)",
      "default": 80,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_laptop",
      "label": "Padding Bottom (Laptop)",
      "default": 80,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Tablet Padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom (Tablet)",
      "default": 60,
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 40,
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "section-list",
      "name": "Image & Content Section",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "reverse_layout",
          "label": "Change Position"
        },
        {
          "type": "image_picker",
          "id": "first_img",
          "label": "First Icon Image"
        },
        {
          "type": "image_picker",
          "id": "sec_img",
          "label": "Second Icon Image"
        },
        {
          "type": "image_picker",
          "id": "third_img",
          "label": "Third Icon Image"
        },
        {
          "type": "text",
          "id": "sec_heading",
          "label": "Add Title"
        },
        {
          "type": "richtext",
          "id": "sec_dec",
          "label": "Add Description"
        },
        {
          "type": "text",
          "id": "sec_btn",
          "label": "Button label (Desktop)"
        },
        {
          "type": "text",
          "id": "sec_btn_mobile",
          "label": "Button label (Mobile)",
          "info": "If it's empty, there will be text from the desktop version." 
        },
        {
          "type": "url",
