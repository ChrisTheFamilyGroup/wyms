{{ 'wyms-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'wyms-header.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  :root {
    --header-logo-width: {{ section.settings.logo_width }}px;
  }
{%- endstyle -%}

<wyms-header class="header-section">
  <div class="header-outer-container page-width">
    
    <div class="header-main-box">
      
      <div class="header-block header-block--burger hide-desktop">
        <button type="button" class="icon-div-wrapper js-mobile-open" aria-label="Open Menu">
          {% render 'icon-hamburger' %}
        </button>
      </div>

      <div class="header-block header-block--logo">
        <a href="{{ routes.root_url }}" class="header-logo-link">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 400 | image_tag: class: 'header-logo-img', preload: true }}
          {%- else -%}
            <span class="display-xs">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <div class="header-divider hide-mobile"></div>

      <div class="header-block header-block--nav hide-mobile">
        <nav class="header-nav-desktop" role="navigation">
          {%- for i in (1..3) -%}
            {%- assign label_key = "menu_label_" | append: i -%}
            {%- assign menu_key = "menu_" | append: i -%}
            {%- assign icon_key = "menu_icon_" | append: i -%}
            
            {%- assign custom_label = section.settings[label_key] -%}
            {%- assign menu = linklists[section.settings[menu_key]] -%}
            
            {%- if custom_label != blank -%}
              <div class="nav-item-wrapper">
                <div class="nav-item-main-trigger">
                  <a href="{{ menu.url | default: '#' }}" class="nav-link-text">
                    {{ custom_label }}
                  </a>
                  {%- if section.settings[icon_key] != blank -%}
                    {{ section.settings[icon_key] | image_url: width: 48 | image_tag: class: 'nav-hover-icon', loading: 'lazy' }}
                  {%- endif -%}
                </div>
                
                {%- if menu != blank and menu.links.size > 0 -%}
                  <div class="desktop-flyout-menu">
                    {%- for link in menu.links -%}
                      <a href="{{ link.url }}" class="flyout-item">
                        <span class="flyout-item-text">{{ link.title }}</span>
                      </a>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      </div>

      <div class="header-divider hide-mobile"></div>

      {% comment %} === 4. ICONS (Right) === {% endcomment %}
      <div class="header-block header-block--icons">
        <div class="header-user-actions">
          <a href="{{ routes.search_url }}" class="icon-div-wrapper hide-mobile">{% render 'icon-search' %}</a>
          <a href="{{ routes.account_url }}" class="icon-div-wrapper hide-mobile">{% render 'icon-account' %}</a>
          <button type="button" class="icon-div-wrapper cart-drawer-trigger">
            {% render 'icon-cart' %}
            <span class="cart-count-badge js-cart-count{% if cart.item_count == 0 %} is-hidden{% endif %}">{{ cart.item_count }}</span>
          </button>
        </div>
      </div>

    </div>

  </div>

  <div class="mobile-menu-overlay" id="MobileNav" style="display: none;">
    <div class="mobile-menu-card">
      <div class="mobile-menu-header-row">
        <button type="button" class="icon-div-wrapper js-mobile-close">{% render 'icon-close' %}</button>
        <div class="mobile-logo-center">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 200 | image_tag: class: 'header-logo-img', loading: 'lazy' }}
          {%- endif -%}
        </div>
        <button type="button" class="icon-div-wrapper cart-drawer-trigger">
          {% render 'icon-cart' %}
          <span class="cart-count-badge js-cart-count{% if cart.item_count == 0 %} is-hidden{% endif %}">{{ cart.item_count }}</span>
        </button>
      </div>

      <div class="mobile-menu-nav-container">
        <div class="mobile-nav-page" id="MobileMainList">
          {%- for i in (1..3) -%}
            {%- assign label_key = "menu_label_" | append: i -%}
            {%- assign menu_key = "menu_" | append: i -%}
            {%- assign custom_label = section.settings[label_key] -%}
            {%- assign menu = linklists[section.settings[menu_key]] -%}

            {%- if custom_label != blank -%}
              <div class="mobile-nav-item {% if menu != blank and menu.links.size > 0 %}js-open-submenu{% endif %}" data-target="submenu-{{ i }}">
                <span class="mobile-nav-text-main">{{ custom_label }}</span>
                {%- if menu != blank and menu.links.size > 0 -%}{% render 'icon-chevron-right' %}{%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- for i in (1..3) -%}
          {%- assign label_key = "menu_label_" | append: i -%}
          {%- assign menu_key = "menu_" | append: i -%}
          {%- assign menu = linklists[section.settings[menu_key]] -%}
          
          {%- if menu != blank and menu.links.size > 0 -%}
            <div class="mobile-nav-page submenu-page" id="submenu-{{ i }}" style="display: none;">
              <div class="mobile-nav-item submenu-header-row js-back-to-main">
                {% render 'icon-chevron-left' %}
                <span class="mobile-nav-text-main fw-semibold">{{ section.settings[label_key] }}</span>
                <div style="width: 20px;"></div>
              </div>
              <div class="mobile-submenu-links-list">
                {%- for link in menu.links -%}
                  <a href="{{ link.url }}" class="mobile-nav-item">
                    <span class="mobile-nav-text-sub">{{ link.title }}</span>
                  </a>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
       <div class="mobile-menu-footer-actions">
        <a href="{{ routes.search_url }}" class="mobile-footer-icon-wrapper" aria-label="Search">
          {% render 'icon-search' %}
        </a>
        <a href="{{ routes.account_url }}" class="mobile-footer-icon-wrapper" aria-label="Account">
          {% render 'icon-account' %}
        </a>
      </div>
    </div>
  </div>
</wyms-header>

{% schema %}
{
  "name": "WYMS Header",
  "settings": [
    { "type": "image_picker", 
      "id": "logo", 
      "label": "Logo" 
    },
    { "type": "range", 
      "id": "logo_width",
       "min": 50, 
       "max": 200, 
       "step": 5, 
       "unit": "px", 
       "label": "Logo width", 
       "default": 95 
    },
    { "type": "header", 
      "content": "Navigation Item 1" 
    },
    { "type": "text", 
      "id": "menu_label_1", 
      "label": "Label 1", 
      "default": "Produkte" 
    },
    { "type": "link_list", 
      "id": "menu_1", 
      "label": "Menu 1" 
    },
    { "type": "image_picker", 
      "id": "menu_icon_1", 
      "label": "Hover Icon 1" 
    },
    { "type": "header", 
      "content": "Navigation Item 2" 
    },
    { "type": "text", 
      "id": "menu_label_2", 
      "label": "Label 2", 
      "default": "Über uns" 
    },
    { "type": "link_list", 
      "id": "menu_2", 
      "label": "Menu 2" 
    },
    { "type": "image_picker", 
      "id": "menu_icon_2", 
      "label": "Hover Icon 2" 
    },
    { "type": "header", 
      "content": "Navigation Item 3" 
    },
    { "type": "text", 
      "id": "menu_label_3",
      "label": "Label 3", 
      "default": "Hilfe" 
    },
    { "type": "link_list",
      "id": "menu_3", 
      "label": "Menu 3" 
    },
    { "type": "image_picker", 
      "id": "menu_icon_3", 
      "label": "Hover Icon 3" 
    }
  ],
  "presets": [{ "name": "WYMS Header" }]
}
{% endschema %}