{{ 'wyms-product-description.css' | asset_url | stylesheet_tag }}
<script src="{{ 'wyms-product-description.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign heading    = product.metafields.custom.description_heading
  assign subtext    = product.metafields.custom.description_subtext
  assign faq_list   = product.metafields.custom.faq_list.value
  assign info_cards = product.metafields.custom.info_cards.value

  assign faq_bg_val    = section.settings.faq_bg_custom    | default: section.settings.faq_bg    | default: '#FBFBFB'
  assign faq_q_val     = section.settings.faq_q_color_custom | default: section.settings.faq_q_color | default: '#191839'
  assign faq_a_val     = section.settings.faq_a_color_custom | default: section.settings.faq_a_color | default: '#414651'

  # FAQ rich-text answers: replace literal tokens like {{ sku }} in the rich text (loop below).
  assign faq_variant = product.selected_or_first_available_variant
  assign faq_sku = faq_variant.sku | default: '' | strip
  assign faq_barcode = faq_variant.barcode | default: '' | strip

  assign faq_weight = ''
  if faq_variant.weight != blank and faq_variant.weight_unit != blank
    assign faq_weight = faq_variant.weight | weight_with_unit: faq_variant.weight_unit
  endif

  # Size: variant or product metafield (custom.product_size)
  assign faq_size = faq_variant.metafields.custom.product_size.value | default: product.metafields.custom.product_size.value | default: '' | strip

  # Color: category metafield shopify.color-pattern (often list.metaobject_reference; not always on variant in Liquid)
  assign faq_color = ''
  assign faq_color_mf = faq_variant.metafields.shopify['color-pattern']
  if faq_color_mf == blank
    assign faq_color_mf = product.metafields.shopify['color-pattern']
  endif
  if faq_color_mf != blank
    assign faq_color = faq_color_mf | metafield_text: field: 'label' | strip
    if faq_color == blank
      assign faq_color = faq_color_mf | metafield_text: field: 'name' | strip
    endif
  endif
  if faq_color == blank and faq_color_mf != blank
    assign faq_color_val = faq_color_mf.value
    if faq_color_mf.list?
      assign faq_color_val = faq_color_val.first
    endif
    if faq_color_val.label != blank
      assign faq_color = faq_color_val.label | strip
    elsif faq_color_val.name != blank
      assign faq_color = faq_color_val.name | strip
    elsif faq_color_val != blank
      assign faq_color = faq_color_val | strip
    endif
  endif
  if faq_color == blank
    for product_option in product.options_with_values
      assign faq_swatch_opts = product_option.values | map: 'swatch' | compact | size
      if faq_swatch_opts == 0
        continue
      endif
      case product_option.position
        when 1
          assign faq_opt_pick = faq_variant.option1 | default: '' | strip
        when 2
          assign faq_opt_pick = faq_variant.option2 | default: '' | strip
        when 3
          assign faq_opt_pick = faq_variant.option3 | default: '' | strip
        else
          assign faq_opt_pick = ''
      endcase
      for product_option_value in product_option.values
        if product_option_value.selected or product_option_value.name == faq_opt_pick
          assign faq_color = product_option_value.name | strip
          break
        endif
      endfor
      if faq_color != blank
        break
      endif
    endfor
  endif

  # FAQ token replacements insert into rendered rich text HTML — escape inserts only (not whole markup).
  assign faq_t_sku = faq_sku | escape
  assign faq_t_barcode = faq_barcode | escape
  assign faq_t_color = faq_color | escape
  assign faq_t_weight = faq_weight | escape
  assign faq_t_size = faq_size | escape
-%}

{% comment %} {% if description_subtext != blank %} {% endcomment %}
<wyms-product-desc
  id="description"
  class="wyms-desc-outer"
>
  <div class="wyms-desc-section"
    style="
      background-color: {{ section.settings.section_bg | default: '#6865EA' }};
      --wyms-title-color:   {{ section.settings.title_color   | default: '#191839' }};
      --wyms-subtext-color: {{ section.settings.subtext_color | default: '#414651' }};
      --wyms-faq-q-color:   {{ faq_q_val }};
      --wyms-faq-a-color:   {{ faq_a_val }};
      --wyms-faq-bg:        {{ faq_bg_val }};
    "
  >
    <div class="wyms-desc-inner">
      <div class="wyms-desc-grid">

        {%- comment -%} LEFT COLUMN — Text & Accordion {%- endcomment -%}
        <div class="wyms-desc-left">

          <div class="wyms-desc-text-header">
            {%- if heading != blank -%}
              <h2 class="wyms-desc-title">{{ heading }}</h2>
            {%- endif -%}
            {%- if subtext != blank -%}
              <div class="wyms-desc-subtext">{{ subtext | newline_to_br }}</div>
            {%- endif -%}
          </div>

          {%- if faq_list != blank -%}
            <div class="wyms-desc-faq-container">
              {%- for faq in faq_list -%}
                {%- liquid
                  assign q = faq.question | default: faq.question.value
                  assign a = faq.answer | metafield_tag
                  assign a = a | replace: '{{ sku }}', faq_t_sku
                  assign a = a | replace: '{{ barcode }}', faq_t_barcode
                  assign a = a | replace: '{{ color }}', faq_t_color
                  assign a = a | replace: '{{ weight }}', faq_t_weight
                  assign a = a | replace: '{{ size }}', faq_t_size
                -%}
                <div class="wyms-faq-item js-faq-item">
                  <button type="button" class="wyms-faq-trigger js-faq-trigger" aria-expanded="false">

                    <div class="wyms-faq-content">
                      <span class="wyms-faq-question">{{ q }}</span>

                      <div class="wyms-faq-answer-wrapper">
                        <div class="wyms-faq-answer-inner">
                          <div class="wyms-faq-answer-text rte">{{ a }}</div>
                        </div>
                      </div>
                    </div>

                    <div class="wyms-faq-icon">
                      <svg class="icon-plus" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <svg class="icon-minus" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>

                  </button>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        </div>

        {%- comment -%} RIGHT COLUMN — Info Cards {%- endcomment -%}
        <div class="wyms-desc-right">
          {%- if info_cards != blank -%}
            {%- for card in info_cards -%}
              {%- liquid
                assign card_bg    = card.background_color | default: '#FBFBFB'
                assign card_color = card.text_color       | default: '#191839'
                assign card_text  = card.text             | default: card.text.value
              -%}
              <div class="wyms-info-card" style="background-color: {{ card_bg }};">
                {%- if card.icon != blank -%}
                  <div class="wyms-card-icon">
                    {{ card.icon | image_url: width: 160 | image_tag: loading: 'lazy', width: 80, height: 80 }}
                  </div>
                {%- endif -%}
                <p class="wyms-card-text" style="color: {{ card_color }};">{{ card_text }}</p>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>
</wyms-product-desc>

{% comment %} {% endif %} {% endcomment %}

{% schema %}
{
  "name": "WYMS Product Desc & FAQ",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#191839"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Description text color",
      "default": "#414651"
    },
    {
      "type": "header",
      "content": "Accordion (FAQ)"
    },
    {
      "type": "color",
      "id": "faq_bg",
      "label": "FAQ item background (solid color)",
      "default": "#FBFBFB"
    },
    {
      "type": "text",
      "id": "faq_bg_custom",
      "label": "FAQ item background (overrides above, supports rgba)",
      "placeholder": "e.g. rgba(255, 255, 255, 0.20)"
    },
    {
      "type": "color",
      "id": "faq_q_color",
      "label": "Question text color",
      "default": "#191839"
    },
    {
      "type": "text",
      "id": "faq_q_color_custom",
      "label": "Question color override (supports rgba)",
      "placeholder": "e.g. rgba(255, 255, 255, 0.90)"
    },
    {
      "type": "color",
      "id": "faq_a_color",
      "label": "Answer text color",
      "default": "#414651"
    },
    {
      "type": "text",
      "id": "faq_a_color_custom",
      "label": "Answer color override (supports rgba)",
      "placeholder": "e.g. rgba(255, 255, 255, 0.70)"
    }
  ],
  "presets": [
    {
      "name": "WYMS Product Desc & FAQ"
    }
  ]
}
{% endschema %}
