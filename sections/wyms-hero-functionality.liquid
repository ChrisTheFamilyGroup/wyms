{{ 'wyms-hero-functionality.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_content = false
  if section.settings.heading != blank or section.settings.main_image != blank
    assign has_content = true
  endif
-%}

{%- if has_content or request.design_mode -%}
  <section class="wyms-hero-func">
    
    {%- if has_content == false and request.design_mode -%}
      <div class="wyms-hero-func__empty-state">
        <h3>Functionality Hero section is empty</h3>
        <p>Please add a heading or an image in the section settings.</p>
      </div>
    {%- else -%}

      <div class="wyms-hero-func__wrapper-white">
        
        <div class="wyms-hero-func__wrapper-green" style="background-color: {{ section.settings.bg_color }};">
          
          <div class="wyms-hero-func__inner">
            
            <div class="wyms-hero-func__text-col">
              {%- if section.settings.top_text != blank -%}
                <div class="wyms-hero-func__top-text">{{ section.settings.top_text }}</div>
              {%- endif -%}
              
              {%- if section.settings.heading != blank -%}
                <h1 class="wyms-hero-func__heading">{{ section.settings.heading }}</h1>
              {%- endif -%}
            </div>

            <div class="wyms-hero-func__image-col">
              
              <div class="wyms-hero-func__media-wrapper">
                {%- if section.settings.blob_image != blank -%}
                  <img src="{{ section.settings.blob_image | image_url: width: 1000 }}" 
                       alt="" 
                       class="wyms-hero-func__blob" 
                       loading="eager"
                       width="900"
                       height="900">
                {%- endif -%}

                {%- if section.settings.main_image != blank -%}
                  <img src="{{ section.settings.main_image | image_url: width: 1000 }}" 
                       alt="{{ section.settings.heading | escape }}" 
                       class="wyms-hero-func__main-img" 
                       loading="eager"
                       width="900"
                       height="900">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg wyms-hero-func__main-img' }}
                {%- endif -%}
              </div>

            </div>

          </div>
        </div>
      </div>

    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "WYMS Hero Functionality",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#CFF804"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Top Small Text",
      "default": "Everything in view"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Heading",
      "default": "Klarheit im Inneren."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Product Image"
    },
    {
      "type": "image_picker",
      "id": "blob_image",
      "label": "Background Blob Image"
    }
  ],
  "presets": [
    {
      "name": "WYMS Hero Functionality"
    }
  ]
}
{% endschema %}