{%- comment -%}
  Horizontal sticky CTA bar; pins below the header while scrolling.
  SYNCED LOGIC: 0px when flowing, 16px when stuck (scrolling down), Header Height when stuck (scrolling up).
{%- endcomment -%}

<div class="wyms-sticky-btns-section js-sticky-section-wrapper">
  <div
    id="StickyBtnsBar-{{ section.id }}"
    class="wyms-sticky-btns-section__bar js-sticky-bar-element"
    data-wyms-sticky-btns-bar
  >
    <div class="wyms-sticky-btns-section__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'main_btns' -%}
          <a
            class="wyms-sticky-btns-section__link"
            href="{{ block.settings.sec_btn_link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.sec_btn_icon != blank -%}
              <img
                src="{{ block.settings.sec_btn_icon | image_url: width: 96 }}"
                alt="{{ block.settings.sec_btn_icon.alt | escape }}"
                class="img-fluid wyms-sticky-btns-section__icon"
                loading="lazy"
                width="{{ block.settings.sec_btn_icon.width }}"
                height="{{ block.settings.sec_btn_icon.height }}"
              >
            {%- endif -%}
            {%- if block.settings.sec_btn_text != blank -%}
              <span class="wyms-sticky-btns-section__label">{{ block.settings.sec_btn_text }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    position: -webkit-sticky;
    position: sticky;
    top: -1px; 
    z-index: 99;
    background: #fff;
    display: block !important;
  }

  #shopify-section-{{ section.id }} .wyms-sticky-btns-section {
    position: relative;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  .wyms-sticky-btns-section__bar {
    padding-top: 0 !important; 
    padding-bottom: 16px;
    background: #fff;
    width: 100%;
    box-sizing: border-box;
    border-bottom: 1px solid #e2dbd3;
    transition: padding-top 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .wyms-sticky-btns-section__bar.is-stuck {
    padding-top: var(--wyms-product-nav-inset, 105px) !important;
  }

  body.header-is-hidden #shopify-section-{{ section.id }} .wyms-sticky-btns-section__bar.is-stuck {
    padding-top: 16px !important; 
  }

  .wyms-sticky-btns-section__inner {
    display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;
  }
  .wyms-sticky-btns-section__icon { height: 20px; width: 20px; object-fit: contain; }
  .wyms-sticky-btns-section__link {
    display: flex; align-items: center; gap: 6px; color: #191839; text-decoration: none;
    background: #efebe6; padding: 10px 14px; border-radius: 9999px;
    transition: background-color 0.4s ease, color 0.4s ease;
    font-family: var(--font-family-body, 'Inter', sans-serif);
    font-size: 18px; font-weight: 600; line-height: 28px;
  }
  .wyms-sticky-btns-section__label { color: #191839; font-size: 14px; font-weight: 600; }
  .wyms-sticky-btns-section__link:hover { background: #00103f; color: #fff; }

  @media (max-width: 1599.98px) {
    #shopify-section-{{ section.id }} .wyms-sticky-btns-section {
      padding-top: {{ section.settings.padding_top_laptop }}px;
      padding-bottom: {{ section.settings.padding_bottom_laptop }}px;
    }
  }
  @media (max-width: 1024.98px) {
    #shopify-section-{{ section.id }} .wyms-sticky-btns-section {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
    .wyms-sticky-btns-section__label { font-size: 12px; }
  }
  @media (max-width: 767.98px) {
    #shopify-section-{{ section.id }} .wyms-sticky-btns-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .wyms-sticky-btns-section__inner {
      flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch;
      scrollbar-width: none; padding: 0 16px; gap: 8px; justify-content: flex-start;
    }
    .wyms-sticky-btns-section__inner::-webkit-scrollbar { display: none; }
    .wyms-sticky-btns-section__link { flex-shrink: 0; font-size: 14px; padding: 10px 14px; }
  }
</style>

<script>
  (function () {
    const root = document.getElementById('shopify-section-{{ section.id }}');
    const bar = root.querySelector('.js-sticky-bar-element');
    if (!root || !bar) return;

    const observer = new IntersectionObserver(
      ([e]) => {
        // Ми додаємо клас is-stuck тільки коли заголовок торкається верху
        bar.classList.toggle('is-stuck', e.intersectionRatio < 1);
      },
      { 
        threshold: [1],
        rootMargin: '-1px 0px 0px 0px' 
      }
    );
    observer.observe(root);
  })();
</script>

{% schema %}
{
  "name": "Sticky buttons",
  "settings": [
    { "type": "header", "content": "Desktop padding" },
    { "type": "range", "id": "padding_top_desktop", "label": "Padding top (desktop)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bottom (desktop)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "header", "content": "Laptop padding" },
    { "type": "range", "id": "padding_top_laptop", "label": "Padding top (laptop)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "range", "id": "padding_bottom_laptop", "label": "Padding bottom (laptop)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "header", "content": "Tablet padding" },
    { "type": "range", "id": "padding_top_tablet", "label": "Padding top (tablet)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "range", "id": "padding_bottom_tablet", "label": "Padding bottom (tablet)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "header", "content": "Mobile padding" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "default": 0, "min": 0, "max": 150, "step": 5, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "default": 0, "min": 0, "max": 150, "step": 5, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "main_btns",
      "name": "Button",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "sec_btn_text", "label": "Button text" },
        { "type": "image_picker", "id": "sec_btn_icon", "label": "Button icon" },
        { "type": "url", "id": "sec_btn_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [{ "name": "Sticky buttons", "category": "Custom" }]
}
{% endschema %}