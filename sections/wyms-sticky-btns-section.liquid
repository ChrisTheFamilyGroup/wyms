{%- comment -%}
  Sticky horizontal CTA bar: pins with `top: var(--wyms-sticky-top-inset)` from wyms-header.js (measured header height; 16px when header hidden).
  No IntersectionObserver padding toggles — those caused layout ↔ observer feedback (jumping).
{%- endcomment -%}

<div class="wyms-sticky-btns-section js-sticky-section-wrapper">
  <div
    id="StickyBtnsBar-{{ section.id }}"
    class="wyms-sticky-btns-section__bar js-sticky-bar-element"
    data-wyms-sticky-btns-bar
  >
    <div class="wyms-sticky-btns-section__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'main_btns' -%}
          <a
            class="wyms-sticky-btns-section__link"
            href="{{ block.settings.sec_btn_link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.sec_btn_icon != blank -%}
              <div class="wyms-sticky-btns-section__icon-container">
                <img
                  src="{{ block.settings.sec_btn_icon | image_url: width: 40 }}"
                  alt="{{ block.settings.sec_btn_icon.alt | escape }}"
                  class="img-fluid wyms-sticky-btns-section__icon icon-normal"
                  loading="lazy"
                  width="20"
                  height="20"
                >
                {%- if block.settings.sec_btn_icon_white != blank -%}
                  <img
                    src="{{ block.settings.sec_btn_icon_white | image_url: width: 40 }}"
                    alt="Hover icon"
                    class="img-fluid wyms-sticky-btns-section__icon icon-hover"
                    loading="lazy"
                    width="20"
                    height="20"
                  >
                {%- endif -%}
              </div>
            {%- endif -%}
            
            {%- if block.settings.sec_btn_text != blank -%}
              <span class="wyms-sticky-btns-section__label">{{ block.settings.sec_btn_text }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  /* 1. STICKY: `top` follows header height from wyms-header.js. No IO/padding hacks (layout ↔ observer feedback = jump). */
  #shopify-section-{{ section.id }} {
    position: -webkit-sticky;
    position: sticky;
    top: var(--wyms-sticky-top-inset, 0px);
    z-index: 99;
    background: transparent;
    display: block !important;
    transition: top 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #shopify-section-{{ section.id }} .wyms-sticky-btns-section {
    position: relative;
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  /* 2. BAR — transparent track; only pill links carry surface color (no full-bleed bar while scrolling). */
  .wyms-sticky-btns-section__bar {
    padding-top: 0;
    padding-bottom: 16px;
    background: transparent;
    width: 100%;
    box-sizing: border-box;
    border-bottom: none;
    box-shadow: none;
  }

  /* 3. ICON HOVER STYLES */
  .wyms-sticky-btns-section__icon-container {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .wyms-sticky-btns-section__icon {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  .icon-hover { opacity: 0; }

  /* 4. BUTTON DESIGN & HOVER */
  .wyms-sticky-btns-section__inner {
    display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;
  }

  .wyms-sticky-btns-section__link {
    display: flex; align-items: center; gap: 6px; color: #191839; text-decoration: none;
    background: #efebe6; padding: 10px 14px; border-radius: 9999px;
    transition: background-color 0.3s ease, color 0.3s ease;
    font-family: var(--font-family-body, 'Inter', sans-serif);
    font-size: 18px; font-weight: 600; line-height: 28px;
  }

  .wyms-sticky-btns-section__label {
    color: #191839; font-family: inherit; font-size: 14px; font-weight: 600; line-height: 20px;
    transition: color 0.3s ease;
  }

  /* --- HOVER EFFECT --- */
  .wyms-sticky-btns-section__link:hover {
    background-color: #191839 !important;
    color: #ffffff !important;
  }

  .wyms-sticky-btns-section__link:hover .wyms-sticky-btns-section__label {
    color: #ffffff !important;
  }

  .wyms-sticky-btns-section__link:hover .icon-normal { opacity: 0; }
  .wyms-sticky-btns-section__link:hover .icon-hover { opacity: 1; }

  /* 5. RESPONSIVE ADAPTATIONS (schema has desktop + mobile only — avoid invalid `padding-top: px`) */
  @media (max-width: 1024.98px) {
    .wyms-sticky-btns-section__label { font-size: 12px; }
  }
  @media (max-width: 767.98px) {
    #shopify-section-{{ section.id }} .wyms-sticky-btns-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .wyms-sticky-btns-section__inner {
      flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch;
      scrollbar-width: none; padding: 0 16px; gap: 8px; justify-content: flex-start;
    }
    .wyms-sticky-btns-section__inner::-webkit-scrollbar { display: none; }
    .wyms-sticky-btns-section__link { flex-shrink: 0; font-size: 14px; padding: 10px 14px; }
    .wyms-sticky-btns-section__icon-container { width: 15px; height: 15px; }
  }
</style>

<script>
  /**
   * Publish measured sticky pill-bar height for anchor scroll-margin (see wyms-ergonomic-content-with-bg).
   * Runs once per bar; updates on resize and when header changes --wyms-sticky-top-inset.
   */
  (function () {
    const bars = document.querySelectorAll('[data-wyms-sticky-btns-bar]');
    if (!bars.length) return;

    const root = document.documentElement;

    const publish = () => {
      let max = 0;
      bars.forEach((el) => {
        if (el instanceof HTMLElement) {
          max = Math.max(max, Math.ceil(el.getBoundingClientRect().height));
        }
      });
      const next = `${Math.max(max, 1)}px`;
      if (root.style.getPropertyValue('--wyms-sticky-btns-chrome').trim() !== next) {
        root.style.setProperty('--wyms-sticky-btns-chrome', next);
      }
    };

    if (window.ResizeObserver) {
      const ro = new ResizeObserver(() => requestAnimationFrame(publish));
      bars.forEach((el) => ro.observe(el));
    }

    ['wyms:sticky-top-inset', 'wyms:header-visible', 'wyms:header-hidden'].forEach((ev) => {
      document.addEventListener(ev, () => requestAnimationFrame(publish));
    });
    window.addEventListener('resize', () => requestAnimationFrame(publish), { passive: true });
    window.addEventListener('load', () => requestAnimationFrame(publish), { passive: true });
    if (document.fonts?.ready) {
      document.fonts.ready.then(() => requestAnimationFrame(publish)).catch(() => {});
    }
    requestAnimationFrame(publish);
  })();
</script>

{% schema %}
{
  "name": "Sticky buttons",
  "settings": [
    { "type": "header", "content": "Desktop padding" },
    { "type": "range", "id": "padding_top_desktop", "label": "Padding top (desktop)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bottom (desktop)", "default": 0, "min": 0, "max": 200, "step": 5, "unit": "px" },
    { "type": "header", "content": "Mobile padding" },
    { "type": "range", "id": "padding_top_mobile", "label": "Padding top (mobile)", "default": 0, "min": 0, "max": 150, "step": 5, "unit": "px" },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Padding bottom (mobile)", "default": 0, "min": 0, "max": 150, "step": 5, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "main_btns",
      "name": "Button",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "sec_btn_text", "label": "Button text" },
        { "type": "image_picker", "id": "sec_btn_icon", "label": "Normal Icon" },
        { "type": "image_picker", "id": "sec_btn_icon_white", "label": "Hover Icon (White)" },
        { "type": "url", "id": "sec_btn_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [{ "name": "Sticky buttons", "category": "Custom" }]
}
{% endschema %}